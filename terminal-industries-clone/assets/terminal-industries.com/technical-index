1264,1901,2155,2717,3108,3549,3998,4451,4864,5577,6026,6135,6263,6407,6556,6722,6925,7193,7609,7769,8102,8242,8611,9005,9337],{"name":1265,"created_at":1266,"published_at":1267,"updated_at":1268,"id":1269,"uuid":1270,"content":1271,"slug":1893,"full_slug":1894,"sort_by_date":139,"position":1895,"tag_list":1896,"is_startpage":49,"parent_id":1897,"meta_data":139,"group_id":1898,"first_published_at":1899,"release_id":139,"lang":1161,"path":139,"alternates":1900,"default_full_slug":139,"translated_slugs":139},"How AI Is Transforming Yard Throughput, Reducing Bottlenecks, and Strengthening Supply Chain Resilience","2026-03-03T16:14:40.327Z","2026-03-11T16:39:45.475Z","2026-03-11T16:39:45.503Z",150998549844020,"9903b7a7-6576-456c-bf7e-a955569c8ef2",{"_uid":1272,"body":1273,"link":1880,"title":1265,"author":1881,"excerpt":1284,"category":1232,"is_gated":49,"subtitle":18,"component":1883,"seo_image":1884,"seo_title":1886,"button_text":132,"cover_image":1887,"seo_noindex":49,"seo_description":1889,"background_color":1890,"featured_in_latest_news":49},"4f1b269a-e648-43ae-ad1d-b465cfa574a0",{"type":66,"content":1274},[1275,1280,1285,1290,1295,1311,1350,1355,1360,1402,1407,1412,1417,1422,1459,1464,1501,1506,1543,1548,1553,1558,1563,1568,1603,1608,1645,1650,1687,1692,1697,1702,1707,1751,1756,1800,1805,1810,1815,1820,1825,1830,1835,1865,1870,1875],{"type":69,"attrs":1276,"content":1277},{"level":138,"textAlign":139},[1278],{"text":1279,"type":75},"Executive Summary",{"type":112,"attrs":1281,"content":1282},{"textAlign":139},[1283],{"text":1284,"type":75},"Logistics companies are increasingly using artificial intelligence to optimize yard throughput, reduce truck wait times, eliminate operational bottlenecks, and adapt to supply chain disruptions. AI-driven platforms combine real-time visibility, predictive analytics, automated scheduling, and workflow orchestration to transform yards from reactive environments into dynamically managed systems. By coordinating gate operations, dock assignments, trailer movements, and scheduling in real time, AI improves asset utilization, reduces congestion, and increases operational resilience.",{"type":69,"attrs":1286,"content":1287},{"level":138,"textAlign":139},[1288],{"text":1289,"type":75},"How Are Logistics Companies Using AI to Optimize Yard Throughput?",{"type":112,"attrs":1291,"content":1292},{"textAlign":139},[1293],{"text":1294,"type":75},"Logistics companies use AI to optimize yard throughput by orchestrating yard movements, predicting congestion before it occurs, and dynamically assigning resources based on real-time conditions.",{"type":112,"attrs":1296,"content":1297},{"textAlign":139},[1298,1300,1309],{"text":1299,"type":75},"AI platforms ",{"text":1301,"type":75,"marks":1302},"improve throughput",[1303],{"type":1304,"attrs":1305},"link",{"href":1306,"uuid":1307,"anchor":139,"target":1308,"linktype":19},"/blog/beyond-throughput-real-world-roi-from-ai-powered-yard-deployments","f7c97e00-093a-4683-b2a1-fd10c5258890","_self",{"text":1310,"type":75}," by:",{"type":1312,"content":1313},"bullet_list",[1314,1322,1329,1336,1343],{"type":1315,"content":1316},"list_item",[1317],{"type":112,"attrs":1318,"content":1319},{"textAlign":139},[1320],{"text":1321,"type":75},"Predicting inbound truck arrivals using historical and real-time data",{"type":1315,"content":1323},[1324],{"type":112,"attrs":1325,"content":1326},{"textAlign":139},[1327],{"text":1328,"type":75},"Automatically assigning dock doors based on load priority and yard position",{"type":1315,"content":1330},[1331],{"type":112,"attrs":1332,"content":1333},{"textAlign":139},[1334],{"text":1335,"type":75},"Coordinating yard jockey movements to minimize empty moves",{"type":1315,"content":1337},[1338],{"type":112,"attrs":1339,"content":1340},{"textAlign":139},[1341],{"text":1342,"type":75},"Monitoring trailer dwell time and flagging congestion risk",{"type":1315,"content":1344},[1345],{"type":112,"attrs":1346,"content":1347},{"textAlign":139},[1348],{"text":1349,"type":75},"Dynamically sequencing tasks to avoid bottlenecks",{"type":112,"attrs":1351,"content":1352},{"textAlign":139},[1353],{"text":1354,"type":75},"Instead of managing the yard through manual calls, whiteboards, or reactive workflows, AI enables continuous optimization. The system evaluates constraints across gates, staging areas, dock doors, and yard equipment to maximize flow.",{"type":112,"attrs":1356,"content":1357},{"textAlign":139},[1358],{"text":1359,"type":75},"The result is:",{"type":1312,"content":1361},[1362,1369,1381,1388,1395],{"type":1315,"content":1363},[1364],{"type":112,"attrs":1365,"content":1366},{"textAlign":139},[1367],{"text":1368,"type":75},"Increased truck turns per day",{"type":1315,"content":1370},[1371],{"type":112,"attrs":1372,"content":1373},{"textAlign":139},[1374],{"text":1375,"type":75,"marks":1376},"Reduced dwell time",[1377],{"type":1304,"attrs":1378},{"href":1379,"uuid":1380,"anchor":139,"target":1308,"linktype":19},"/global/features-carousel-items/container-dwell-time-tracking","8c155e07-d156-4229-bbb7-4d41094a40d4",{"type":1315,"content":1382},[1383],{"type":112,"attrs":1384,"content":1385},{"textAlign":139},[1386],{"text":1387,"type":75},"Higher trailer utilization",{"type":1315,"content":1389},[1390],{"type":112,"attrs":1391,"content":1392},{"textAlign":139},[1393],{"text":1394,"type":75},"Lower detention costs",{"type":1315,"content":1396},[1397],{"type":112,"attrs":1398,"content":1399},{"textAlign":139},[1400],{"text":1401,"type":75},"Improved driver experience",{"type":112,"attrs":1403,"content":1404},{"textAlign":139},[1405],{"text":1406,"type":75},"Throughput is no longer dependent on manual coordination. It becomes algorithmically managed.",{"type":69,"attrs":1408,"content":1409},{"level":138,"textAlign":139},[1410],{"text":1411,"type":75},"How Can AI-Driven Platforms Reduce Operational Bottlenecks in Logistics?",{"type":112,"attrs":1413,"content":1414},{"textAlign":139},[1415],{"text":1416,"type":75