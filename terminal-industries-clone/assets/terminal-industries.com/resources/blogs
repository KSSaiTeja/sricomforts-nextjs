e":1229,"taggings_count":1230},"guide",22,{"name":1232,"taggings_count":1233},"Logistics Technology ",43,{"name":1235,"taggings_count":1236},"metrics",13,{"name":1238,"taggings_count":1239},"route optimization",19,{"name":1241,"taggings_count":71},"security",{"name":1243,"taggings_count":1244},"technology",37,{"name":1246,"taggings_count":1247},"yms",4,{"stories":1249,"total":3959,"perPage":3960,"page":71},[1250,1644,1942,2127,2461,2626,2915,3109,3378,3408,3525,3864],{"name":1251,"created_at":1252,"published_at":1253,"updated_at":1254,"id":1255,"uuid":1256,"content":1257,"slug":1636,"full_slug":1637,"sort_by_date":139,"position":1638,"tag_list":1639,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":1641,"first_published_at":1642,"release_id":139,"lang":1161,"path":139,"alternates":1643,"default_full_slug":139,"translated_slugs":139},"OCR Reads the Plate. Computer Vision Runs the Yard","2026-06-25T14:49:41.924Z","2026-06-25T16:55:39.874Z","2026-06-25T16:55:39.890Z",191321628389302,"962611ff-7a87-4bc7-a47a-c8d0b2938179",{"_uid":1258,"body":1259,"link":1616,"title":1617,"author":1618,"excerpt":1620,"category":1621,"is_gated":49,"subtitle":1622,"component":1623,"seo_image":1624,"seo_title":1626,"button_text":132,"cover_image":1627,"gated_asset":1631,"seo_noindex":49,"seo_description":1632,"background_color":1633,"featured_in_latest_news":49},"47caa694-c807-4eec-a112-c13dc425c1be",{"type":66,"content":1260},[1261,1270,1278,1286,1294,1302,1310,1318,1326,1334,1342,1356,1370,1384,1392,1400,1408,1416,1424,1432,1440,1448,1462,1476,1490,1504,1512,1520,1534,1548,1562,1576,1584,1592,1600,1608],{"type":112,"attrs":1262,"content":1263},{"textAlign":139},[1264],{"text":1265,"type":75,"marks":1266},"Walk a logistics buyer through three vendor demos this year and all three will say the same four words: \"AI-powered computer vision.\" A camera reads a license plate on the screen, a number populates a field, and everyone nods. It looks like the same technology.",[1267],{"type":149,"attrs":1268},{"color":1269},"#000000",{"type":112,"attrs":1271,"content":1272},{"textAlign":139},[1273],{"text":1274,"type":75,"marks":1275},"It isn't. And the gap between what those demos are actually doing is the difference between a faster clipboard and a system that runs your yard.",[1276],{"type":149,"attrs":1277},{"color":1269},{"type":112,"attrs":1279,"content":1280},{"textAlign":139},[1281],{"text":1282,"type":75,"marks":1283},"Most of what gets sold as \"vision at the gate\" is optical character recognition. OCR is real, it's useful, and it's also forty years old. Terminal does something categorically different. Understanding why matters, because the buyers who can't tell the two apart are the ones who write off \"computer vision\" after a disappointing pilot, when what disappointed them was never computer vision at all.",[1284],{"type":149,"attrs":1285},{"color":1269},{"type":69,"attrs":1287,"content":1288},{"level":138,"textAlign":139},[1289],{"text":1290,"type":75,"marks":1291},"What OCR actually does, and where it stops",[1292],{"type":149,"attrs":1293},{"color":1269},{"type":112,"attrs":1295,"content":1296},{"textAlign":139},[1297],{"text":1298,"type":75,"marks":1299},"OCR has one job: turn a picture of text into a string of characters. Point it at a license plate and it gives you the plate number. Point it at a trailer and it reads the ID stenciled on the door. That's it. That's the entire capability.",[1300],{"type":149,"attrs":1301},{"color":1269},{"type":112,"attrs":1303,"content":1304},{"textAlign":139},[1305],{"text":1306,"type":75,"marks":1307},"It's the same technology that scans a check or digitizes a paper form, aimed at a truck. When a gate vendor says \"our camera reads the plate,\" they are describing OCR, and they are describing the ceiling of what the system can do, not the floor.",[1308],{"type":149,"attrs":1309},{"color":1269},{"type":112,"attrs":1311,"content":1312},{"textAlign":139},[1313],{"text":1314,"type":75,"marks":1315},"Here is the part the demo doesn't show you. After OCR reads the characters, a human still has to do everything that matters. Is this truck on today's appointment list? Which dock is open? Is the carrier legitimate? Is that a trailer or a container, and does it need fuel or a power connection? Is there fresh damage on the panel? OCR can't answer any of that. It hands you a number and walks away. Your guard, your dispatcher, and your clerk pick up exactly where they always did.",[1316],{"type":149,"attrs":1317},{"color":1269},{"type":112,"attrs":1319,"content":1320},{"textAlign":139},[1321],{"text":1322,"type":75,"marks":1323},"That's why so many \"smart gates\" don't feel smart. They digitized the slowest keystroke at the gate and left the actual work untouched. You replaced a guard writing a plate on a clipboard with a camera writing a plate to a database. Faster data entry is not a transformed yard.",[1324],{"type":149,"attrs":1325},{"color":1269},{"type":69,"attrs":1327,"content":1328},{"level":138,"textAlign":139},[1329],{"text":1330,"type":75,"marks":1331},"What Terminal does that OCR can't",[1332],{"type":149,"attrs":1333},{"color":1269},{"type":112,"attrs":1335,"content":1336},{"textAlign":139},[1337],{"text":1338,"type":75,"marks":1339},"Terminal's computer vision is built in three layers. OCR is one small piece of the first one.",[1340],{"type":149,"attrs":1341},{"color":1269},{"type":112,"attrs":1343,"content":1344},{"textAlign":139},[1345,1351],{"text":1346,"type":75,"marks":1347},"It reads.",[1348,1350],{"type":149,"attrs":1349},{"color":1269},{"type":710},{"text":1352,"type":75,"marks":1353}," Yes, Terminal captures the text: license plate, USDOT and motor carrier number, VIN, and trailer, container, and chassis IDs. This is the part that looks like OCR, except it runs against the industry's largest yard-specific data models and lands above 50% improvement over manual capture, which is why Ryder's Karen Jones called the accuracy \"a significant milestone in the race to modernize the yard.\" No RFID, no BLE tags, no specialized rigs. Off-the-shelf cameras, because the intelligence lives in the software, not on the pole.",[1354],{"type":149,"attrs":1355},{"color":1269},{"type":112,"attrs":1357,"content":1358},{"textAlign":139},[1359,1365],{"text":1360,"type":75,"marks":1361},"It classifies and understands the scene.",[1362,1364],{"type":149,"attrs":1363},{"color":1269},{"type":710},{"text":1366,"type":75,"marks":1367}," This is where OCR ends and computer vision begins. Terminal doesn't just read characters, it identifies what it's looking at. Trailer versus container versus chassis. Container size and type. Class and fuel type. Carrier logos. Seal presence and seal number. The operating state of a reefer unit, set temperature and current reading off the display. The condition of the asset on the way in. OCR sees a string. Terminal sees the truck, the trailer, the load, and the state they're all in, and it understands that scene the way an experienced yard worker would, every time, on every lane, without getting tired at shift change.",[1368],{"type":149,"attrs":1369},{"color":1269},{"type":112,"attrs":1371,"content":1372},{"textAlign":139},[1373,1379],{"text":1374,"type":75,"marks":1375},"It acts.",[1376,1378],{"type":149,"attrs":1377},{"color":1269},{"type":710},{"text":1380,"type":75,"marks":1381}," A read and a classification are still just data until something happens. Terminal turns what it sees into the next move automatically. If the truck matches the appointment and the carrier clears, the gate opens and the trailer registers as on-yard. If the carrier's risk score says hold, the truck is stopped before the arm ever lifts. A reefer below its fuel threshold doesn't get admitted. A container gets routed differently than a trailer, with the right yard action surfaced for the right asset in the right spot. We connect these into what we call Missions: multi-step, traceable movements from gate to dock that the system orchestrates on its own.",[1382],{"type":149,"attrs":1383},{"color":1269},{"type":112,"attrs":1385,"content":1386},{"textAlign":139},[1387],{"text":1388,"type":75,"marks":1389},"OCR gives you a record. Terminal makes a decision.",[1390],{"type":149,"attrs":1391},{"color":1269},{"type":69,"attrs":1393,"content":1394},{"level":138,"textAlign":139},[1395],{"text":1396,"type":75,"marks":1397},"The difference, in one line",[1398],{"type":149,"attrs":1399},{"color":1269},{"type":112,"attrs":1401,"content":1402},{"textAlign":139},[1403],{"text":1404,"type":75,"marks":1405},"Legacy systems, and the OCR-at-the-gate tools bolted onto them, record what already happened. Terminal orchestrates what happens next.",[1406],{"type":149,"attrs":1407},{"color":1269},{"type":112,"attrs":1409,"content":1410},{"textAlign":139},[1411],{"text":1412,"type":75,"marks":1413},"OCR is the purest example of recording. It is, quite literally, a machine for writing down what it saw. That has value, the way a faster typist has value. But it leaves you reactive. You still find out about the problem after the truck is inside the fence, after the wrong trailer left the dock, after the reefer drifted out of range, after the fraudulent carrier drove off with the load.",[1414],{"type":149,"attrs":1415},{"color":1269},{"type":112,"attrs":1417,"content":1418},{"textAlign":139},[1419],{"text":1420,"type":75,"marks":1421},"As we put it when we launched our security layer: a fraudulent carrier at the gate at 9:14 AM is not a ticket to be reviewed later. It is a decision that has to be made before the gate arm opens. OCR can write down that the truck arrived. Only a system that sees, understands, and acts can stop it.",[1422],{"type":149,"attrs":1423},{"color":1269},{"type":69,"attrs":1425,"content":1426},{"level":138,"textAlign":139},[1427],{"text":1428,"type":75,"marks":1429},"The hard part isn't the vision. It's operationalizing it.",[1430],{"type":149,"attrs":1431},{"color":1269},{"type":112,"attrs":1433,"content":1434},{"textAlign":139},[1435],{"text":1436,"type":75,"marks":1437},"Here's the fair objection a sharp buyer raises next: if reading, classifying, and acting is the bar, couldn't any computer vision vendor clear it? In a demo, maybe. In a live yard, across hundreds of sites, in the rain, at 2 AM, on every asset that rolls in, it's a different problem entirely. Operationalizing computer vision for the yard is where the real difference lives, and it's the part you can't see in a slide.",[1438],{"type":149,"attrs":1439},{"color":1269},{"type":112,"attrs":1441,"content":1442},{"textAlign":139},[1443],{"text":1444,"type":75,"marks":1445},"Four things make Terminal's vision work in the field, not just in the deck.",[1446],{"type":149,"attrs":1447},{"color":1269},{"type":112,"attrs":1449,"content":1450},{"textAlign":139},[1451,1457],{"text":1452,"type":75,"marks":1453},"The models keep getting better.",[1454,1456],{"type":149,"attrs":1455},{"color":1269},{"type":710},{"text":1458,"type":75,"marks":1459}," A computer vision system you install is a system that starts aging the day it goes live. Ours is the opposite. We are constantly training and updating our models, so accuracy improves and the range of what the system can recognize and act on expands over time. The yard you deploy this quarter is running a more capable system next quarter, with no forklift upgrade.",[1460],{"type":149,"attrs":1461},{"color":1269},{"type":112,"attrs":1463,"content":1464},{"textAlign":139},[1465,1471],{"text":1466,"type":75,"marks":1467},"It tunes to your yard, not a generic one.",[1468,1470],{"type":149,"attrs":1469},{"color":1269},{"type":710},{"text":1472,"type":75,"marks":1473}," No two yards are the same. Layouts, lighting, lane configurations, asset mix, regional plates, and local quirks all differ, and a frozen one-size-fits-all model breaks on the exceptions, which in a yard is most of the day. Terminal's vision system adapts and tunes to the specific conditions and use cases in the field, so it performs on your operation as it actually runs, not on the clean version in a brochure.",[1474],{"type":149,"attrs":1475},{"color":1269},{"type":112,"attrs":1477,"content":1478},{"textAlign":139},[1479,1485],{"text":1480,"type":75,"marks":1481},"It's one vision system used many ways, not a pile of point tools.",[1482,1484],{"type":149,"attrs":1483},{"color":1269},{"type":710},{"text":1486,"type":75,"marks":1487}," This is the part competitors can't reverse-engineer from a feature list. Terminal's gate capture, real-time location across the yard, and perimeter security are not three products from three vendors stitched together. They are the same vision system applied to different jobs, sharing one data model and one source of truth. The plate the gate read is the same asset that RTLS is locating and the same one security is watching. Buy three point solutions and you get three silos that don't talk to each other. Build on Terminal and every capability inherits from the same vision layer, which is exactly why the system interlocks instead of leaking at the seams.",[1488],{"type":149,"attrs":1489},{"color":1269},{"type":112,"attrs":1491,"content":1492},{"textAlign":139},[1493,1499],{"text":1494,"type":75,"marks":1495},"We know the yard.",[1496,1498],{"type":149,"attrs":1497},{"color":1269},{"type":710},{"text":1500,"type":75,"marks":1501}," This is not a science project. The hardest part of putting AI vision into a yard isn't the AI, it's knowing what a yard actually does: how drop-and-hook differs from a live load, why a spotter move happens when it does, what a gate guard is really checking for. Terminal pairs deep vision and AI engineering with deep logistics operating experience across the whole company, from development and engineering to go-to-market, deployment, and support. We were founded by operators (Ryder, NFI, Lineage, and Prologis) for exactly that reason. The vision technology is necessary. Knowing the yard is what makes it work.",[1502],{"type":149,"attrs":1503},{"color":1269},{"type":69,"attrs":1505,"content":1506},{"level":138,"textAlign":139},[1507],{"text":1508,"type":75,"marks":1509},"What this translates to in the yard",[1510],{"type":149,"attrs":1511},{"color":1269},{"type":112,"attrs":1513,"content":1514},{"textAlign":139},[1515],{"text":1516,"type":75,"marks":1517},"The category difference shows up as business value in four places an operator can actually measure.",[1518],{"type":149,"attrs":1519},{"color":1269},{"type":112,"attrs":1521,"content":1522},{"textAlign":139},[1523,1529],{"text":1524,"type":75,"marks":1525},"Speed and throughput.",[1526,1528],{"type":149,"attrs":1527},{"color":1269},{"type":710},{"text":1530,"type":75,"marks":1531}," Vision capture and automated check-in move a truck through the gate in seconds instead of the fourteen minutes a manual gate averages. Multiply that across every arrival and you cut dwell, shrink detention exposure, and turn the yard faster without adding a lane or a clerk.",[1532],{"type":149,"attrs":1533},{"color":1269},{"type":112,"attrs":1535,"content":1536},{"textAlign":139},[1537,1543],{"text":1538,"type":75,"marks":1539},"Labor.",[1540,1542],{"type":149,"attrs":1541},{"color":1269},{"type":710},{"text":1544,"type":75,"marks":1545}," Computer vision does the work people used to do on foot. The system always knows what's in the yard and where it sits, so your team stops walking the lot to count assets, and the gate, dispatch, and yard-check roles that OCR left fully staffed start to come down.",[1546],{"type":149,"attrs":1547},{"color":1269},{"type":112,"attrs":1549,"content":1550},{"textAlign":139},[1551,1557],{"text":1552,"type":75,"marks":1553},"Errors and claims.",[1554,1556],{"type":149,"attrs":1555},{"color":1269},{"type":710},{"text":1558,"type":75,"marks":1559}," Reading the plate right is table stakes. Confirming the right trailer is at the right door with the right freight before it moves is what prevents mis-ships, OS&D claims, and broken chain of custody. Classification and verification do that. OCR doesn't.",[1560],{"type":149,"attrs":1561},{"color":1269},{"type":112,"attrs":1563,"content":1564},{"textAlign":139},[1565,1571],{"text":1566,"type":75,"marks":1567},"Fraud and compliance.",[1568,1570],{"type":149,"attrs":1569},{"color":1269},{"type":710},{"text":1572,"type":75,"marks":1573}," Carrier risk gets scored before the truck arrives. Driver identity gets matched to the appointment. Conveyance condition and seal numbers get captured as a timestamped, photo-backed record, the kind of CTPAT-grade inspection most yards still do on paper, if they do it at all. That record is the difference between defending a claim and eating it.",[1574],{"type":149,"attrs":1575},{"color":1269},{"type":112,"attrs":1577,"content":1578},{"textAlign":139},[1579],{"text":1580,"type":75,"marks":1581},"Across these, the outcome our customers see is 4x or more ROI inside the first year, on a platform that goes live in as little as five days. You don't get that from reading characters faster. You get it from a system that runs the yard.",[1582],{"type":149,"attrs":1583},{"color":1269},{"type":69,"attrs":1585,"content":1586},{"level":138,"textAlign":139},[1587],{"text":1588,"type":75,"marks":1589},"The takeaway for buyers",[1590],{"type":149,"attrs":1591},{"color":1269},{"type":112,"attrs":1593,"content":1594},{"textAlign":139},[1595],{"text":1596,"type":75,"marks":1597},"Stop evaluating gate cameras on whether they can read a plate. They all can, more or less, and reading the plate was never the hard part.",[1598],{"type":149,"attrs":1599},{"color":1269},{"type":112,"attrs":1601,"content":1602},{"textAlign":139},[1603],{"text":1604,"type":75,"marks":1605},"Start asking the question that separates a faster clipboard from a transformed operation: after the camera reads it, who decides, and who acts? If the answer is still your guard, your dispatcher, and your clerk, you bought OCR. If the answer is the system itself, you bought computer vision.",[1606],{"type":149,"attrs":1607},{"color":1269},{"type":112,"attrs":1609,"content":1610},{"textAlign":139},[1611],{"text":1612,"type":75,"marks":1613},"That's the line. And it's the whole game.",[1614],{"type":149,"attrs":1615},{"color":1269},{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},"OCR Reads the Plate, Computer Vision Runs the Yard.",[1619],"4970a15a-a518-4e01-a0de-cb3b272e0fe4","OCR (the \"AI camera\" most gate vendors actually sell) just reads characters into a string and hands the work back to your guard, dispatcher, and clerk, which is why a faster clipboard never transforms a yard. Terminal's computer vision reads, then classifies and understands the whole scene, then acts on it (open the gate, hold the fraudulent carrier, route the reefer), turning recorded data into orchestrated decisions worth 4x ROI in year one.","blog","Why \"we use AI cameras at the gate\" can mean two completely different things, and why the difference is the whole game.","Post",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":1625},{},"OCR vs. Computer Vision in the Yard | Terminal Industries",{"id":1628,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1629,"copyright":18,"fieldtype":1105,"meta_data":1630,"is_external_url":49},191336446793782,"/storyblok/f/337048/1510x980/058e2ef5d7/computer-vision-at-gate.png",{},[],"Most \"AI gate cameras\" are just OCR reading a plate. See how Terminal's computer vision reads, understands, and acts to run the yard, not just record it.",{"value":1634,"plugin":1635},"#c2c2c2","storyblok-palette","ocr-reads-the-plate-computer-vision-runs-the-yard","all-resources/ocr-reads-the-plate-computer-vision-runs-the-yard",-2350,[1214,1225,1243,1246],80887824638261,"9165d819-e166-4d42-bfeb-8c26ff721b22","2026-06-25T15:52:43.238Z",[],{"name":1645,"created_at":1646,"published_at":1647,"updated_at":1648,"id":1649,"uuid":1650,"content":1651,"slug":1935,"full_slug":1936,"sort_by_date":139,"position":1937,"tag_list":1938,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":1939,"first_published_at":1940,"release_id":139,"lang":1161,"path":139,"alternates":1941,"default_full_slug":139,"translated_slugs":139},"The CV market is having its SaaSpocalypse moment","2026-06-22T16:34:08.111Z","2026-06-25T15:55:53.059Z","2026-06-25T15:55:53.075Z",190285611491708,"e185b904-4a08-41d4-8db2-03829cffc791",{"_uid":1652,"body":1653,"link":1919,"title":1920,"author":1921,"excerpt":1923,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":1924,"seo_title":1926,"button_text":132,"cover_image":1927,"gated_asset":1931,"seo_noindex":49,"seo_description":1932,"background_color":1933,"featured_in_latest_news":49},"836efd9f-94df-4e48-84c7-5171d2e725ed",{"type":66,"content":1654},[1655,1663,1671,1679,1687,1695,1704,1718,1726,1739,1747,1760,1778,1787,1795,1803,1824,1833,1841,1850,1858,1867,1875,1887,1895,1903,1911],{"type":112,"attrs":1656,"content":1657},{"textAlign":139},[1658],{"text":1659,"type":75,"marks":1660},"Depending on who has a vested stake, the \"SaaSpocalypse\" may or may not happen. We've seen traditional enterprise B2B SaaS companies move fast to deploy new AI solutions, even when they're bolted on after the fact.",[1661],{"type":149,"attrs":1662},{"color":1269},{"type":112,"attrs":1664,"content":1665},{"textAlign":139},[1666],{"text":1667,"type":75,"marks":1668},"Supply chain is no different. Legacy tech providers are shipping chatbots (glorified AI, if we're honest), and I'm sure some customers have found value in them.",[1669],{"type":149,"attrs":1670},{"color":1269},{"type":112,"attrs":1672,"content":1673},{"textAlign":139},[1674],{"text":1675,"type":75,"marks":1676},"What hasn't changed across any industry is the underlying business model. Customers of every size are still forced to buy overpriced software packages with 50+ features and modules when they need two or three for their specific job. The cost of traditional SaaS, plus the lengthy implementation schedules and fees that come with it, is actively holding everyone back from adopting the latest technology, from supply chain VPs to 3PLs.",[1677],{"type":149,"attrs":1678},{"color":1269},{"type":112,"attrs":1680,"content":1681},{"textAlign":139},[1682],{"text":1683,"type":75,"marks":1684},"With AI-native alternatives, the need to buy a massive package with a massive price tag no longer serves the market. Compounding this is the terrible user experience; once you’ve used an AI-native platform, the experience of trying to manage critical tasks through a bolt-on is painful. That's the genesis of the SaaSpocalypse.",[1685],{"type":149,"attrs":1686},{"color":1269},{"type":112,"attrs":1688,"content":1689},{"textAlign":139},[1690],{"text":1691,"type":75,"marks":1692},"I'd argue computer vision is heading for the same reckoning. CV players burst onto the scene over the last decade and priced their starting packages in the six figures. But the price of computer vision has not kept pace with the rate of technological development, as hardware got cheaper, models got better, and the cost to deploy decreased significantly.",[1693],{"type":149,"attrs":1694},{"color":1269},{"type":112,"attrs":1696,"content":1697},{"textAlign":139},[1698],{"text":1699,"type":75,"marks":1700},"So why does CV still cost what it costs? It doesn't have to. Four things changed underneath the market, and legacy pricing never caught up.",[1701,1703],{"type":149,"attrs":1702},{"color":1269},{"type":710},{"type":112,"attrs":1705,"content":1706},{"textAlign":139},[1707,1713],{"text":1708,"type":75,"marks":1709},"Change 1: The architecture is AI-native, not retrofitted.",[1710,1712],{"type":149,"attrs":1711},{"color":1269},{"type":710},{"text":1714,"type":75,"marks":1715}," ",[1716],{"type":149,"attrs":1717},{"color":1269},{"type":112,"attrs":1719,"content":1720},{"textAlign":139},[1721],{"text":1722,"type":75,"marks":1723},"Legacy vendors built their platforms in a pre-AI world and have spent years grafting intelligence onto an old foundation. Every bolt-on carries a cost, and that cost gets passed to you as the buyer. When a provider is able to build for AI from the ground up, the economics start in a completely different place.",[1724],{"type":149,"attrs":1725},{"color":1269},{"type":112,"attrs":1727,"content":1728},{"textAlign":139},[1729,1735],{"text":1730,"type":75,"marks":1731},"Change 2: The pricing is as-a-service, not perpetual license plus fees.",[1732,1734],{"type":149,"attrs":1733},{"color":1269},{"type":710},{"text":1714,"type":75,"marks":1736},[1737],{"type":149,"attrs":1738},{"color":1269},{"type":112,"attrs":1740,"content":1741},{"textAlign":139},[1742],{"text":1743,"type":75,"marks":1744},"You shouldn't pay six figures up front for capabilities you haven't used yet. As-a-service pricing ties what you spend to the value you get, and it kills the implementation tax that has padded CV invoices for a decade.",[1745],{"type":149,"attrs":1746},{"color":1269},{"type":112,"attrs":1748,"content":1749},{"textAlign":139},[1750,1756],{"text":1751,"type":75,"marks":1752},"Change 3: The models are better, and better is cheaper.",[1753,1755],{"type":149,"attrs":1754},{"color":1269},{"type":710},{"text":1714,"type":75,"marks":1757},[1758],{"type":149,"attrs":1759},{"color":1269},{"type":112,"attrs":1761,"content":1762},{"textAlign":139},[1763,1773],{"text":1764,"type":75,"marks":1765},"Modern CV models ",[1766,1771],{"type":1767,"attrs":1768},"link",{"href":1769,"uuid":258,"anchor":139,"target":1770,"linktype":19},"/terminal-ai-computer-vision","_self",{"type":149,"attrs":1772},{"color":1269},{"text":1774,"type":75,"marks":1775},"deliver higher accuracy per dollar of compute than the hand-tuned, bespoke systems of the 2010s, and the capability gap is widening in the buyer's favor every quarter.",[1776],{"type":149,"attrs":1777},{"color":1269},{"type":112,"attrs":1779,"content":1780},{"textAlign":139},[1781],{"text":1782,"type":75,"marks":1783},"Change 4: Hardware is more accessible than ever",[1784,1786],{"type":149,"attrs":1785},{"color":1269},{"type":710},{"type":112,"attrs":1788,"content":1789},{"textAlign":139},[1790],{"text":1791,"type":75,"marks":1792},"You no longer need specialized, expensive camera rigs to run serious computer vision. Off-the-shelf cameras and edge compute do the work, because the intelligence lives in the software. The expensive part of CV is no longer the part you bolt to a pole.",[1793],{"type":149,"attrs":1794},{"color":1269},{"type":112,"attrs":1796,"content":1797},{"textAlign":139},[1798],{"text":1799,"type":75,"marks":1800},"Put those four together and the math is simple. We can deliver computer vision that's priced for ROI, well below what's on the market and twice as powerful, because the cost structure underneath it has fundamentally changed.",[1801],{"type":149,"attrs":1802},{"color":1269},{"type":112,"attrs":1804,"content":1805},{"textAlign":139},[1806,1811,1819],{"text":1807,"type":75,"marks":1808},"This is an interesting dichotomy, because the generation of CV solutions offer premium features and returns, but at an affordable price point. ",[1809],{"type":149,"attrs":1810},{"color":1269},{"text":1812,"type":75,"marks":1813},"The ROI is demonstrable ",[1814,1817],{"type":1767,"attrs":1815},{"href":1816,"uuid":735,"anchor":139,"target":1770,"linktype":19},"/yard-efficiency-calculator",{"type":149,"attrs":1818},{"color":1269},{"text":1820,"type":75,"marks":1821},"and it shows up in – yet again – four distinct places an operator can measure:  ",[1822],{"type":149,"attrs":1823},{"color":1269},{"type":112,"attrs":1825,"content":1826},{"textAlign":139},[1827],{"text":1828,"type":75,"marks":1829},"Speed",[1830,1832],{"type":149,"attrs":1831},{"color":1269},{"type":710},{"type":112,"attrs":1834,"content":1835},{"textAlign":139},[1836],{"text":1837,"type":75,"marks":1838},"Vision capture and automated check-in move a truck through the gate in seconds instead of minutes. Multiply that across every arrival and you cut dwell, shrink detention exposure, and turn the yard faster without adding a lane or a clerk. Not to mention the opportunity to replace RFID solutions. ",[1839],{"type":149,"attrs":1840},{"color":1269},{"type":112,"attrs":1842,"content":1843},{"textAlign":139},[1844],{"text":1845,"type":75,"marks":1846},"Labor",[1847,1849],{"type":149,"attrs":1848},{"color":1269},{"type":710},{"type":112,"attrs":1851,"content":1852},{"textAlign":139},[1853],{"text":1854,"type":75,"marks":1855},"Computer vision does the work people used to do on foot. The system always knows what's in the yard and where it sits, so your team doesn’t manage millions of inventory by walking around the lot. ",[1856],{"type":149,"attrs":1857},{"color":1269},{"type":112,"attrs":1859,"content":1860},{"textAlign":139},[1861],{"text":1862,"type":75,"marks":1863},"Error reduction",[1864,1866],{"type":149,"attrs":1865},{"color":1269},{"type":710},{"type":112,"attrs":1868,"content":1869},{"textAlign":139},[1870],{"text":1871,"type":75,"marks":1872},"Load verification confirms the right trailer is at the right door with the right freight before it moves. That means fewer mis-ships, fewer OS&D claims, and a secure chain of custody. ",[1873],{"type":149,"attrs":1874},{"color":1269},{"type":112,"attrs":1876,"content":1877},{"textAlign":139},[1878],{"text":1879,"type":75,"marks":1880},"Fines and fraud",[1881,1884,1886],{"type":1767,"attrs":1882},{"href":1883,"uuid":285,"anchor":139,"target":1770,"linktype":19},"/yard-security",{"type":149,"attrs":1885},{"color":1269},{"type":710},{"type":112,"attrs":1888,"content":1889},{"textAlign":139},[1890],{"text":1891,"type":75,"marks":1892},"D&D charges get slashed when trucks can move quickly and efficiently through the lot, compliance exposure decreases when every move is CTPAT compliant, and carrier verification happens even before the truck arrives, and before the load is stolen. ",[1893],{"type":149,"attrs":1894},{"color":1269},{"type":112,"attrs":1896,"content":1897},{"textAlign":139},[1898],{"text":1899,"type":75,"marks":1900},"It makes no sense for buyers to keep accepting legacy CV that's priced and built like the enterprise SaaS of the 2010s.",[1901],{"type":149,"attrs":1902},{"color":1269},{"type":112,"attrs":1904,"content":1905},{"textAlign":139},[1906],{"text":1907,"type":75,"marks":1908},"We're in a new era, and technology buyers deserve better ROI on their investment. That means affordable computer vision that's part of the yard platform you already run, working the gate, the lanes, and the dock instead of sitting in a separate six-figure silo.",[1909],{"type":149,"attrs":1910},{"color":1269},{"type":112,"attrs":1912,"content":1913},{"textAlign":139},[1914],{"text":1915,"type":75,"marks":1916},"I'm a longtime SaaS veteran, and what I'm seeing in the CV market has me excited for the value this new generation of tools will deliver, at a price point that finally makes sense.",[1917],{"type":149,"attrs":1918},{"color":1269},{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},"The CV Market is Having its SaaSpocalypse Moment",[1922],"677433e4-2813-4ca0-b483-977bdd535709","Computer vision is still priced like 2010s enterprise software: six figures up front, long implementations, and a point tool you manage on the side. The economics underneath it have shifted, so Terminal delivers CV at a price built for ROI, folded into the yard platform you already run rather than bolted on beside it.",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":1925},{},"The CV Market Is Having Its SaaSpocalypse Moment",{"id":1928,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1929,"copyright":18,"fieldtype":1105,"meta_data":1930,"is_external_url":49},190290056574799,"/storyblok/f/337048/628x318/b8322ea2bb/computer-vision-ubiquity.jpeg",{},[],"Legacy computer vision is priced like 2010s enterprise SaaS. Four shifts changed the math. Here's why CV should cost less and live inside your yard platform.",{"value":1934,"plugin":1635},"#ABFF02","the-cv-market-is-having-its-saaspocalypse-moment","all-resources/the-cv-market-is-having-its-saaspocalypse-moment",-2340,[1214,1225,1243,1246],"2e890c29-4787-457f-a19d-596e79539bf1","2026-06-22T16:57:40.535Z",[],{"name":1943,"created_at":1944,"published_at":1945,"updated_at":1946,"id":1947,"uuid":1948,"content":1949,"slug":2121,"full_slug":2122,"sort_by_date":139,"position":2123,"tag_list":2124,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":2125,"first_published_at":1945,"release_id":139,"lang":1161,"path":139,"alternates":2126,"default_full_slug":139,"translated_slugs":139},"Beyond the YMS","2026-06-18T00:35:10.188Z","2026-06-18T00:38:39.044Z","2026-06-18T00:38:39.057Z",188634358566832,"3e7f6fdb-d241-4b3b-83ac-0193773b39b0",{"_uid":1950,"body":1951,"link":2108,"title":2109,"author":2110,"excerpt":2112,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":2113,"seo_title":18,"button_text":132,"cover_image":2115,"gated_asset":2119,"seo_noindex":49,"seo_description":18,"background_color":2120,"featured_in_latest_news":49},"d6ff7ee5-4008-4fe2-af40-c6443de54a33",{"type":66,"content":1952},[1953,1958,1963,1968,1973,1978,1983,1988,1993,1998,2003,2008,2013,2018,2023,2028,2033,2038,2043,2048,2053,2058,2063,2068,2073,2078,2083,2088,2093,2098,2100],{"type":112,"attrs":1954,"content":1955},{"textAlign":139},[1956],{"text":1957,"type":75},"A well-known YMS provider recently published a post making the case that a purpose-built YMS beats the yard module bundled into a warehouse management system. On the narrow point, they are right. A yard module is a thin appendage. It was never going to run a dynamic outdoor environment where trucks queue, trailers dwell, and custody changes hands.",{"type":112,"attrs":1959,"content":1960},{"textAlign":139},[1961],{"text":1962,"type":75},"But the post aims at the wrong target. It treats this as a knock on the WMS, and it is not. Your WMS is one of the most important systems you own, and you have spent years and real money making it good at what it does. The problem was never the WMS. The problem is the gap it was never built to see.",{"type":69,"attrs":1964,"content":1965},{"level":138,"textAlign":139},[1966],{"text":1967,"type":75},"The gap between the highway and the warehouse",{"type":112,"attrs":1969,"content":1970},{"textAlign":139},[1971],{"text":1972,"type":75},"Think about where your systems actually live. Your TMS owns the road. Your WMS owns everything inside the four walls. Between them sits the yard: the handoff where the highway becomes the warehouse, and the one place where, for most operators, the data goes dark.",{"type":112,"attrs":1974,"content":1975},{"textAlign":139},[1976],{"text":1977,"type":75},"That gap is not a WMS failure. A WMS is built to optimize inventory and labor inside the building, and it does that well. Asking it to also run the yard through a bolt-on module is asking it to do a job it was never designed for, with a tool nobody really invested in. The result is the visibility gaps and manual workarounds everyone knows too well. The fix is not a better WMS. It is something purpose-built to own the gap and feed the WMS what it has been missing.",{"type":112,"attrs":1979,"content":1980},{"textAlign":139},[1981],{"text":1982,"type":75},"The mistake in the \"bolt-on versus purpose-built YMS\" debate is assuming the choice ends there. It does not.",{"type":69,"attrs":1984,"content":1985},{"level":138,"textAlign":139},[1986],{"text":1987,"type":75},"A list of tasks is not a mission",{"type":112,"attrs":1989,"content":1990},{"textAlign":139},[1991],{"text":1992,"type":75},"Even a purpose-built YMS, the supposed upgrade, is still the same kind of software underneath. It keeps a list of yard tasks. Check in a driver. Assign a door. Log a move. Each one is a row someone updates. The system holds the rows and shows them to you. When the rows fall out of sync with the yard, and they always do, a person reconciles the board by hand. You have traded a thin clipboard for a nicer one.",{"type":112,"attrs":1994,"content":1995},{"textAlign":139},[1996],{"text":1997,"type":75},"An operating system does not keep a list. It runs missions. A mission is a connected sequence of work aimed at an outcome: get this trailer from the gate to the right dock to the next dispatch, with each task triggering the next and adjusting as conditions change. The tasks are not entries to maintain. They are steps to orchestrate.",{"type":112,"attrs":1999,"content":2000},{"textAlign":139},[2001],{"text":2002,"type":75},"A list tells you a trailer is due at door 7. A mission moves it there, reassigns the jockey when door 7 backs up, and re-sequences the next three arrivals around the delay, without waiting for someone to notice and retype the board.",{"type":69,"attrs":2004,"content":2005},{"level":138,"textAlign":139},[2006],{"text":2007,"type":75},"The yard is a data problem",{"type":112,"attrs":2009,"content":2010},{"textAlign":139},[2011],{"text":2012,"type":75},"None of that works if the system is still waiting to be told what happened. Orchestration needs data, and not the thin trickle a person types in between moves. It needs the whole picture, captured continuously and directly from the yard.",{"type":112,"attrs":2014,"content":2015},{"textAlign":139},[2016],{"text":2017,"type":75},"A yard module and a traditional YMS both run on data that people feed them. They are only as current as the last person who remembered to enter something. An AI-native operating system captures the yard itself: what arrived, what moved, what is sitting where, what condition it is in, in real time and without a clipboard in the loop.",{"type":69,"attrs":2019,"content":2020},{"level":138,"textAlign":139},[2021],{"text":2022,"type":75},"This is how you unleash your WMS",{"type":112,"attrs":2024,"content":2025},{"textAlign":139},[2026],{"text":2027,"type":75},"Here is the part that matters most to anyone who has invested heavily in a warehouse management system. A WMS is only as good as the data crossing its threshold. Today that data arrives late and rough. The WMS does not really know a load is on site until someone keys it in. It does not know the right trailer is staged and ready until a supervisor walks out to look. It plans labor and doors against guesses about what is sitting in the yard.",{"type":112,"attrs":2029,"content":2030},{"textAlign":139},[2031],{"text":2032,"type":75},"Close the yard gap and all of that changes. When the yard is captured and orchestrated in real time, the WMS finally gets clean, live input: accurate arrival times, verified contents, dock readiness, the actual state of the yard instead of an estimate. The warehouse stops waiting on the yard and starts working ahead of it. Labor lines up against trucks that are genuinely ready. Doors turn faster. Detention and demurrage fall because the handoff stops stalling.",{"type":112,"attrs":2034,"content":2035},{"textAlign":139},[2036],{"text":2037,"type":75},"That is the real promise. The right yard technology does not compete with your WMS. It bridges the gap between the highway and the warehouse, a data gap and a capability gap, and in doing so it makes the system you already own dramatically more valuable. You are not replacing your warehouse investment. You are finally letting it run at full speed.",{"type":69,"attrs":2039,"content":2040},{"level":138,"textAlign":139},[2041],{"text":2042,"type":75},"Beyond yard management",{"type":112,"attrs":2044,"content":2045},{"textAlign":139},[2046],{"text":2047,"type":75},"Once the system perceives the yard directly, it is not confined to yard management at all. The same data and the same orchestration layer extend into the broader problems operators lose sleep over.",{"type":112,"attrs":2049,"content":2050},{"textAlign":139},[2051],{"text":2052,"type":75},"Security is one example. The fastest-growing cargo theft method is not cutting a fence; it is fraudulent carriers and stolen identities driving loads out the gate with clean paperwork. CargoNet put 2025 losses near $725 million, up roughly 60% in a single year on flat incident volume. A system that only records what a human types at the gate cannot catch that. A system that already sees the driver, the truck, and the load can.",{"type":112,"attrs":2054,"content":2055},{"textAlign":139},[2056],{"text":2057,"type":75},"Damage detection is another. The same perception that runs the gate can flag a damaged trailer or a compromised seal the moment it enters, instead of in a dispute three weeks later. Nobody added a \"damage module.\" It is the same data, asked a different question.",{"type":112,"attrs":2059,"content":2060},{"textAlign":139},[2061],{"text":2062,"type":75},"That is the pattern. Capture the yard, and you solve problems well past the original task list, because they were always data problems hiding in the gap nobody owned.",{"type":69,"attrs":2064,"content":2065},{"level":138,"textAlign":139},[2066],{"text":2067,"type":75},"Why this was not possible before",{"type":112,"attrs":2069,"content":2070},{"textAlign":139},[2071],{"text":2072,"type":75},"The honest reason the industry settled for the bolt-on versus purpose-built debate is that the better option did not exist at a workable price. You chose between a heavy enterprise suite that took a year to stand up and a thin point solution that did one thing. Depth and accessibility were a tradeoff.",{"type":112,"attrs":2074,"content":2075},{"textAlign":139},[2076],{"text":2077,"type":75},"AI-native development collapsed that tradeoff. The perception and orchestration that used to require custom integration and a six-figure services engagement now ship as software. That is what makes a real operating system buildable, and buildable for the operator running five yards, not just the network running five hundred. Start with one yard. Scale to the network.",{"type":69,"attrs":2079,"content":2080},{"level":138,"textAlign":139},[2081],{"text":2082,"type":75},"The actual question",{"type":112,"attrs":2084,"content":2085},{"textAlign":139},[2086],{"text":2087,"type":75},"The WMS yard module was never going to run your yard. Neither is a tool that just keeps a tidier list while the yard, the data, and the value locked inside your existing systems sit out of reach.",{"type":112,"attrs":2089,"content":2090},{"textAlign":139},[2091],{"text":2092,"type":75},"The question is no longer bolt-on or purpose-built. It is whether your yard stays a blind spot between the highway and the warehouse, or becomes the bridge that makes everything on both sides, your WMS included, worth more.",{"type":112,"attrs":2094,"content":2095},{"textAlign":139},[2096],{"text":2097,"type":75},"That is the age of the YOS. And it is now.",{"type":2099},"horizontal_rule",{"type":112,"attrs":2101,"content":2102},{"textAlign":139},[2103],{"text":2104,"type":75,"marks":2105},"Cargo theft figures: Verisk CargoNet 2025 annual supply chain risk analysis (estimated losses near $725M, up ~60% year over year on essentially flat incident volume).",[2106],{"type":2107},"italic",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},"Beyond the YMS: How a Yard Operating System Unlocks Your WMS",[2111],"f387dbd2-db85-4847-91d6-0fb8dfab90c6","The YOS era retires the purpose-built YMS, which is still just a tidier task list, and replaces it with an AI-native system that orchestrates yard missions from data it captures directly. In doing so, it closes the highway-to-warehouse gap and feeds your WMS the clean, live input it needs to finally run at full speed.",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":2114},{},{"id":2116,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":2117,"copyright":18,"fieldtype":1105,"meta_data":2118,"is_external_url":49},188634443387549,"/storyblok/f/337048/692x637/dab3d182fc/old-vs-new.jpg",{"alt":18,"title":18,"source":18,"copyright":18},[],{"value":1934,"plugin":1635},"beyond-the-yms","all-resources/beyond-the-yms",-2320,[],"0b6c9dd7-0fd6-465c-9cd0-98fdcbc40d23",[],{"name":2128,"created_at":2129,"published_at":2130,"updated_at":2131,"id":2132,"uuid":2133,"content":2134,"slug":2454,"full_slug":2455,"sort_by_date":139,"position":2456,"tag_list":2457,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":2458,"first_published_at":2459,"release_id":139,"lang":1161,"path":139,"alternates":2460,"default_full_slug":139,"translated_slugs":139},"If trust in freight is dead, why is it still running the yard?","2026-06-17T23:32:37.997Z","2026-06-17T23:46:56.455Z","2026-06-17T23:46:56.471Z",188618989585127,"2202c3e1-77d8-4df4-bda3-fded1fb95034",{"_uid":2135,"body":2136,"link":2441,"title":2128,"author":2442,"excerpt":2443,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":2444,"seo_title":2446,"button_text":132,"cover_image":2447,"gated_asset":2451,"seo_noindex":49,"seo_description":2452,"background_color":2453,"featured_in_latest_news":49},"2e214bba-8b06-4181-85d1-edd14859a052",{"type":66,"content":2137},[2138,2146,2154,2233,2241,2249,2257,2265,2273,2281,2289,2297,2305,2313,2321,2329,2337,2345,2353,2361,2369,2377,2385,2393,2401,2409,2417,2425,2433],{"type":112,"attrs":2139,"content":2140},{"textAlign":139},[2141],{"text":2142,"type":75,"marks":2143},"I’ve been in the supply chain industry for 30 years. For the past decade or so, as new software solutions flooded the market, anyone who knew “how things really operated,” knew it was an industry run on relationships. Technology was just a supplement to how money, data and freight got moved from A to B. Even with our current AI gold rush, there are still industry veterans who remember faxing bills of lading and are still working with those same colleagues. I’d argue the foundation of the industry – trust, mutual respect, familiarity – has eroded to a point of no return. Not because of technology, but because of prolific freight fraud that has fostered a culture of paranoia across the industry. And as a veteran of yard technology and systems, I can tell you a lot of this distrust starts in the yard. ",[2144],{"type":149,"attrs":2145},{"color":1269},{"type":112,"attrs":2147,"content":2148},{"textAlign":139},[2149],{"text":2150,"type":75,"marks":2151},"Walk into almost any logistics facility in the country and you'll find the same scene at the gate: a person with a tablet or a clipboard. They typically don’t have any information on the trucks coming in – is this the carrier we booked? Is this driver legit? Is that the right trailer, sealed the way it left the last yard? Security and visibility solutions have helped operators answer those questions across almost every node of the supply chain, but in the yard, carrier verification and security is about as sophisticated as the check out process at Costco. ",[2152],{"type":149,"attrs":2153},{"color":1269},{"type":112,"attrs":2155,"content":2156},{"textAlign":139},[2157,2162,2173,2178,2187,2192,2200,2205,2214,2219,2228],{"text":2158,"type":75,"marks":2159},"Cargo theft across the U.S. and Canada ",[2160],{"type":149,"attrs":2161},{"color":1269},{"text":2163,"type":75,"marks":2164},"climbed past $725 million last year",[2165,2168,2171],{"type":1767,"attrs":2166},{"href":2167,"uuid":139,"anchor":139,"target":139,"linktype":96},"https://www.cargonet.com/news-and-events/cargonet-in-the-media/2025-theft-trends/",{"type":149,"attrs":2169},{"color":2170},"#1155CC",{"type":2172},"underline",{"text":2174,"type":75,"marks":2175},", a 60% jump, and the fastest-growing vector isn't the smash-and-grab. It's ",[2176],{"type":149,"attrs":2177},{"color":1269},{"text":2179,"type":75,"marks":2180},"fraud",[2181,2184,2186],{"type":1767,"attrs":2182},{"href":2183,"uuid":139,"anchor":139,"target":139,"linktype":96},"https://www.ic3.gov/PSA/2026/PSA260430",{"type":149,"attrs":2185},{"color":2170},{"type":2172},{"text":2188,"type":75,"marks":2189},": fictitious pickups, stolen identities, carriers that look legitimate on a load board and vanish with a full trailer. The FBI has ",[2190],{"type":149,"attrs":2191},{"color":1269},{"text":2193,"type":75,"marks":2194},"said plainly",[2195,2197,2199],{"type":1767,"attrs":2196},{"href":2183,"uuid":139,"anchor":139,"target":139,"linktype":96},{"type":149,"attrs":2198},{"color":2170},{"type":2172},{"text":2201,"type":75,"marks":2202}," that impersonation is now the dominant way freight gets stolen. And people like the veteran gate guard who knew every regular driver by name is retiring. ",[2203],{"type":149,"attrs":2204},{"color":1269},{"text":2206,"type":75,"marks":2207},"Warehouse turnover sits near 50%",[2208,2211,2213],{"type":1767,"attrs":2209},{"href":2210,"uuid":139,"anchor":139,"target":139,"linktype":96},"https://www.bls.gov/news.release/pdf/jolts.pdf",{"type":149,"attrs":2212},{"color":2170},{"type":2172},{"text":2215,"type":75,"marks":2216},"; for long-haul drivers it's",[2217],{"type":149,"attrs":2218},{"color":1269},{"text":2220,"type":75,"marks":2221}," above 90%",[2222,2225,2227],{"type":1767,"attrs":2223},{"href":2224,"uuid":139,"anchor":139,"target":139,"linktype":96},"https://www.ooida.com/wp-content/uploads/2025/04/The-Churn-A-Brief-Look-at-the-Roots-of-High-Driver-Turnover-in-U.S.-Trucking.pdf",{"type":149,"attrs":2226},{"color":2170},{"type":2172},{"text":2229,"type":75,"marks":2230},". ",[2231],{"type":149,"attrs":2232},{"color":1269},{"type":112,"attrs":2234,"content":2235},{"textAlign":139},[2236],{"text":2237,"type":75,"marks":2238},"So we have a place where every load in the supply chain physically changes hands, where legal custody transfers, where accurate information is scarce or absent, where information asymmetry is accelerating fraud, and where the human safety net is thinning. And it remains the one part of the chain we never really invested in. Go figure. ",[2239],{"type":149,"attrs":2240},{"color":1269},{"type":69,"attrs":2242,"content":2243},{"level":138,"textAlign":139},[2244],{"text":2245,"type":75,"marks":2246},"Yard security is, in fact, the warehouse’s problem ",[2247],{"type":149,"attrs":2248},{"color":1269},{"type":112,"attrs":2250,"content":2251},{"textAlign":139},[2252],{"text":2253,"type":75,"marks":2254},"When a load is stolen through fraud, the strategic theft completes at the moment the trailer is released. The facility that released it is the one left holding the liability. The contractual and compliance obligations that increasingly govern freight (documented carrier vetting, verified driver identity, conveyance inspection, an unbroken chain-of-custody record) all point back to the gate that let the truck through.",[2255],{"type":149,"attrs":2256},{"color":1269},{"type":112,"attrs":2258,"content":2259},{"textAlign":139},[2260],{"text":2261,"type":75,"marks":2262},"Today, cargo insurers, customer contracts, and programs like CTPAT increasingly demand records that paper-based yards cannot produce, and that a gate workforce turning over every eighteen months cannot reliably capture by hand. Yard security is, in fact, the warehouse’s problem, and it has to be solved at the gate, inside the system that runs it, because that's where custody actually changes and where the record either gets made or gets lost.",[2263],{"type":149,"attrs":2264},{"color":1269},{"type":69,"attrs":2266,"content":2267},{"level":138,"textAlign":139},[2268],{"text":2269,"type":75,"marks":2270},"No one owns the yard (and that’s a problem)",[2271],{"type":149,"attrs":2272},{"color":1269},{"type":112,"attrs":2274,"content":2275},{"textAlign":139},[2276],{"text":2277,"type":75,"marks":2278},"I got my first IT job at a 3PL in the early 1990s. It's tempting to say the yard security problem is about bad software, that the industry tried to secure the yard and the tools weren't good enough. But back then the operations team was more worried about people jumping the fence, cutting the seal, and throwing product back over. Technology wasn't available, so companies threw bodies at it.",[2279],{"type":149,"attrs":2280},{"color":1269},{"type":112,"attrs":2282,"content":2283},{"textAlign":139},[2284],{"text":2285,"type":75,"marks":2286},"Yard management software was built for operations and throughput: dock assignments, dwell time, trailer locations, getting trucks in and out efficiently. Security, identity, and chain of custody were understood as separate concerns, owned by separate people, and addressed, when they were addressed at all, by separate means. This is why most facilities outsource the gate to a security company. Some of it got handled by point solutions bolted on from the outside: carrier-vetting services, cameras, physical ID checks by a guy named Steve. A lot of it wasn't handled by software at all.",[2287],{"type":149,"attrs":2288},{"color":1269},{"type":112,"attrs":2290,"content":2291},{"textAlign":139},[2292],{"text":2293,"type":75,"marks":2294},"The result is a set of capabilities that have always lived in paper documentation and verbal communication over a radio – silos – disconnected from each other and from the system that actually runs the yard. For example, the camera never knew who the driver was, the carrier check never reached the gate, and the custody record, where it existed, sat in a binder. None of these pieces were wrong on their own. They simply were never brought together, because for most of the industry's history there was no obvious reason to make changes. ",[2295],{"type":149,"attrs":2296},{"color":1269},{"type":69,"attrs":2298,"content":2299},{"level":138,"textAlign":139},[2300],{"text":2301,"type":75,"marks":2302},"The lesser of two evils",[2303],{"type":149,"attrs":2304},{"color":1269},{"type":112,"attrs":2306,"content":2307},{"textAlign":139},[2308],{"text":2309,"type":75,"marks":2310},"For most of its history, buying yard technology meant choosing between two unsatisfying options, and the choice had nothing to do with security. It was just the shape of the market.",[2311],{"type":149,"attrs":2312},{"color":1269},{"type":112,"attrs":2314,"content":2315},{"textAlign":139},[2316],{"text":2317,"type":75,"marks":2318},"The first option was the large enterprise platform that promised end-to-end control of everything. In practice it was a clunky, glorified system of record: an expensive license, a six month deployment, zero flexibility. It promised comprehensive coverage yet could not change with the business without a massive change request and a matching invoice. You got breadth, and you paid for it in cost and rigidity.",[2319],{"type":149,"attrs":2320},{"color":1269},{"type":112,"attrs":2322,"content":2323},{"textAlign":139},[2324],{"text":2325,"type":75,"marks":2326},"The second was the point solution, with the opposite promise: do one thing exceptionally well. Many genuinely deliver. But when every capability comes from a different vendor, the buyer inherits subscriptions, logins, dashboards, data formats, and renewal cycles, none of which speak to one another. Someone has to integrate them, monitor them, reconcile their outputs, and re-buy them every year. You got depth, and you paid for it in fragmentation.",[2327],{"type":149,"attrs":2328},{"color":1269},{"type":112,"attrs":2330,"content":2331},{"textAlign":139},[2332],{"text":2333,"type":75,"marks":2334},"So that was the trade. Breadth or depth. One expensive, rigid system or ten sharp tools that don't talk. For decades there was no third answer, and no reason to expect one.",[2335],{"type":149,"attrs":2336},{"color":1269},{"type":112,"attrs":2338,"content":2339},{"textAlign":139},[2340],{"text":2341,"type":75,"marks":2342},"AI-native development is the third answer. Capabilities that once demanded a specialized enterprise stack and a year of integration can now be built and deployed in a fraction of the time, at a fraction of the cost. You no longer choose between breadth and depth, or between flexibility and cohesion. You can have technology that does many things at once, changes with the business, and doesn't break the bank or trigger a year of change management.",[2343],{"type":149,"attrs":2344},{"color":1269},{"type":112,"attrs":2346,"content":2347},{"textAlign":139},[2348],{"text":2349,"type":75,"marks":2350},"That is what makes this moment matter for the yard. Once the tradeoff collapses, capabilities that used to demand entirely separate systems can finally live in one. And the two that most need to come together are yard management and yard security, domains that were always treated as separate concerns, owned by separate people, bought from separate vendors. For the first time, there is no reason they have to be.",[2351],{"type":149,"attrs":2352},{"color":1269},{"type":69,"attrs":2354,"content":2355},{"level":138,"textAlign":139},[2356],{"text":2357,"type":75,"marks":2358},"Security should live inside the system already running the gate ",[2359],{"type":149,"attrs":2360},{"color":1269},{"type":112,"attrs":2362,"content":2363},{"textAlign":139},[2364],{"text":2365,"type":75,"marks":2366},"For the first time, the technology exists to create a modular layer inside the system that already runs the yard. The capabilities that secure a yard (knowing the carrier, verifying the driver, watching the perimeter, documenting what actually leaves) no longer have to be a stack of disconnected point tools or a separate enterprise security program.",[2367],{"type":149,"attrs":2368},{"color":1269},{"type":112,"attrs":2370,"content":2371},{"textAlign":139},[2372],{"text":2373,"type":75,"marks":2374},"We’re seeing a great convergence: yard security and yard management becoming one single entity. And AI has made it feasible to build something modular and affordable that does both at once.",[2375],{"type":149,"attrs":2376},{"color":1269},{"type":112,"attrs":2378,"content":2379},{"textAlign":139},[2380],{"text":2381,"type":75,"marks":2382},"Secondarily, we’re able to address both yard security and management because the data is the same data. For example, the check-in event and the security event are not two events; they are one event seen from two angles. The instant a truck reaches the gate, the system logging it for operations already holds nearly everything security needs, such as who is driving, what they are hauling, what the camera sees, and exactly when it happened. Recording that as an operations entry over here and a security entry over there was never a principle of good design.",[2383],{"type":149,"attrs":2384},{"color":1269},{"type":112,"attrs":2386,"content":2387},{"textAlign":139},[2388],{"text":2389,"type":75,"marks":2390},"Security should live inside the system already running the gate.",[2391],{"type":149,"attrs":2392},{"color":1269},{"type":69,"attrs":2394,"content":2395},{"level":138,"textAlign":139},[2396],{"text":2397,"type":75,"marks":2398},"Convergence",[2399],{"type":149,"attrs":2400},{"color":1269},{"type":112,"attrs":2402,"content":2403},{"textAlign":139},[2404],{"text":2405,"type":75,"marks":2406},"Convergence matters because disconnected tools produce alerts, and unified systems produce decisions. A carrier-risk flag in one inbox, an ID scan in another, and a camera feed in a third are three pieces of information someone might later assemble into a conclusion, usually after the truck is already gone. That is retroactive security. It documents how the goods were lost.",[2407],{"type":149,"attrs":2408},{"color":1269},{"type":112,"attrs":2410,"content":2411},{"textAlign":139},[2412],{"text":2413,"type":75,"marks":2414},"A fraudulent carrier at the gate is a decision that has to be made before the arm lifts. It can only be made if the carrier check, the driver's identity, the appointment, and the camera feed are all the same conversation, in the same place, at the same time. That is the entire point of bringing these capabilities together. Convergence isn't about owning fewer vendors, though you will. It's about turning a pile of after-the-fact records into a decision made at the only moment a decision still matters.",[2415],{"type":149,"attrs":2416},{"color":1269},{"type":69,"attrs":2418,"content":2419},{"level":138,"textAlign":139},[2420],{"text":2421,"type":75,"marks":2422},"The yard has always been the supply chain’s soft spot",[2423],{"type":149,"attrs":2424},{"color":1269},{"type":112,"attrs":2426,"content":2427},{"textAlign":139},[2428],{"text":2429,"type":75,"marks":2430},"To be clear, there’s always been freight fraud and the yard was always the soft spot. It’s because it’s where custody is most exposed. What's new is that the excuse is gone and the stakes are higher. Solutions exist that will allow, for the first time, the facility that released the load to prove who took it, prove they were authorized to, and prove that what was left matched what was supposed to. ",[2431],{"type":149,"attrs":2432},{"color":1269},{"type":112,"attrs":2434,"content":2435},{"textAlign":139},[2436],{"text":2437,"type":75,"marks":2438},"That is what this moment in technology actually offers logistics. To give the yard the same visibility and accountability the rest of the supply chain has taken for granted for years.",[2439],{"type":149,"attrs":2440},{"color":1269},{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[1619],"Cargo fraud has made the yard the supply chain's most exposed point, yet yard security and yard management have always been treated as separate problems bought from separate vendors. Terminal's argument: AI-native development has collapsed that tradeoff, making it possible for the first time to converge both into one system at the gate, where custody actually changes and the decision to lift the arm still matters",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":2445},{},"Why Yard Security Belongs Inside Your Yard Management System",{"id":2448,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":2449,"copyright":18,"fieldtype":1105,"meta_data":2450,"is_external_url":49},188621303706158,"/storyblok/f/337048/800x533/789821de04/yard-gate.jpg",{},[],"Freight fraud made the yard the supply chain's soft spot. See why AI-native systems can finally converge yard security and management at the gate, where it counts.",{"value":1934,"plugin":1635},"if-trust-in-freight-is-dead-why-is-it-still-running-the-yard-","all-resources/if-trust-in-freight-is-dead-why-is-it-still-running-the-yard-",-2310,[1214,1220,1232,1241,1246],"3f685df9-91c4-4a64-9531-e80ac5078855","2026-06-17T23:36:58.081Z",[],{"name":2462,"created_at":2463,"published_at":2464,"updated_at":2465,"id":2466,"uuid":2467,"content":2468,"slug":2618,"full_slug":2619,"sort_by_date":2620,"position":2621,"tag_list":2622,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":2623,"first_published_at":2624,"release_id":139,"lang":1161,"path":139,"alternates":2625,"default_full_slug":139,"translated_slugs":139},"The $4.5 Million Freight Theft That Started With a Fake Identity","2026-06-15T21:23:08.304Z","2026-06-15T21:29:03.883Z","2026-06-15T21:29:03.896Z",187879376119444,"6345748b-fb33-456e-9b4d-0a33713467c0",{"_uid":2469,"body":2470,"link":2607,"title":2462,"author":2608,"excerpt":2476,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":2610,"seo_title":2462,"button_text":132,"cover_image":2614,"gated_asset":2616,"seo_noindex":49,"seo_description":2462,"background_color":2617,"featured_in_latest_news":49},"32574d9c-ffee-40e1-83b3-91eeeca0c262",{"type":66,"content":2471},[2472,2477,2482,2487,2492,2497,2502,2507,2512,2517,2522,2527,2532,2537,2542,2547,2552,2557,2562,2567,2572,2577,2582,2587,2592,2597,2602],{"type":112,"attrs":2473,"content":2474},{"textAlign":139},[2475],{"text":2476,"type":75},"For decades, cargo theft looked a certain way. Criminals cut fences, broke locks, and physically stole freight. Security strategies evolved around that reality. Companies invested in gates, cameras, lighting, and guards to keep bad actors out.",{"type":112,"attrs":2478,"content":2479},{"textAlign":139},[2480],{"text":2481,"type":75},"But a recent federal indictment involving an alleged $4.49 million cargo theft scheme tells a different story. According to prosecutors, the individuals involved allegedly impersonated legitimate trucking carriers, accepted loads under false identities, and arranged for freight to be picked up and disappear into the supply chain.",{"type":112,"attrs":2483,"content":2484},{"textAlign":139},[2485],{"text":2486,"type":75},"No fence was cut. No warehouse was broken into. The freight was simply handed over to someone who appeared to be authorized to take it.",{"type":112,"attrs":2488,"content":2489},{"textAlign":139},[2490],{"text":2491,"type":75},"That detail matters because it reflects how cargo theft is changing. Increasingly, theft is no longer a physical security problem. It is an identity problem.",{"type":112,"attrs":2493,"content":2494},{"textAlign":139},[2495],{"text":2496,"type":75},"And nowhere is that more visible than the yard.",{"type":112,"attrs":2498,"content":2499},{"textAlign":139},[2500],{"text":2501,"type":75},"The yard is where custody changes hands. It is where drivers arrive, carriers check in, trailers are assigned, loads are released, and freight physically leaves a facility. Every shipment moving through a warehouse, distribution center, or manufacturing site eventually passes through this point of control.",{"type":112,"attrs":2503,"content":2504},{"textAlign":139},[2505],{"text":2506,"type":75},"Yet many yards still operate with surprisingly limited visibility into who is actually arriving and what authority they have.",{"type":112,"attrs":2508,"content":2509},{"textAlign":139},[2510],{"text":2511,"type":75},"A driver checks in.",{"type":112,"attrs":2513,"content":2514},{"textAlign":139},[2515],{"text":2516,"type":75},"A trailer is assigned.",{"type":112,"attrs":2518,"content":2519},{"textAlign":139},[2520],{"text":2521,"type":75},"A load is released.",{"type":112,"attrs":2523,"content":2524},{"textAlign":139},[2525],{"text":2526,"type":75},"The gate opens.",{"type":112,"attrs":2528,"content":2529},{"textAlign":139},[2530],{"text":2531,"type":75},"Thousands of these transactions happen every day across logistics networks. Most occur without issue. But when a carrier identity has been compromised or fraudulently represented, the yard often becomes the final checkpoint before the freight disappears.",{"type":112,"attrs":2533,"content":2534},{"textAlign":139},[2535],{"text":2536,"type":75},"The challenge is that carrier impersonation rarely looks suspicious. The paperwork may appear legitimate. The carrier name may be familiar. The pickup information may match the shipment. To the human eye, everything can appear normal until it is too late.",{"type":112,"attrs":2538,"content":2539},{"textAlign":139},[2540],{"text":2541,"type":75},"This is why the conversation around yard operations is beginning to change.",{"type":112,"attrs":2543,"content":2544},{"textAlign":139},[2545],{"text":2546,"type":75},"Historically, the industry has focused on moving trucks through the gate as efficiently as possible. Faster check-ins, reduced congestion, and shorter wait times have been the primary objectives.",{"type":112,"attrs":2548,"content":2549},{"textAlign":139},[2550],{"text":2551,"type":75},"Those goals remain important. But as fraud becomes more sophisticated, yards are being asked to do something else: verify.",{"type":112,"attrs":2553,"content":2554},{"textAlign":139},[2555],{"text":2556,"type":75},"Not just who arrived.",{"type":112,"attrs":2558,"content":2559},{"textAlign":139},[2560],{"text":2561,"type":75},"But whether they should be there.",{"type":112,"attrs":2563,"content":2564},{"textAlign":139},[2565],{"text":2566,"type":75},"Not just whether a truck is at the gate.",{"type":112,"attrs":2568,"content":2569},{"textAlign":139},[2570],{"text":2571,"type":75},"But whether that truck is authorized to leave with a specific load.",{"type":112,"attrs":2573,"content":2574},{"textAlign":139},[2575],{"text":2576,"type":75},"In many ways, the future yard is becoming a decision point rather than a traffic checkpoint.",{"type":112,"attrs":2578,"content":2579},{"textAlign":139},[2580],{"text":2581,"type":75},"Every arrival, pickup, and departure creates a moment where the operation can either establish confidence or introduce risk. The facilities that perform best in the coming years will not simply be the ones that move trucks the fastest. They will be the ones that can verify identities, validate appointments, maintain chain of custody, and create a trusted record of every movement across the yard.",{"type":112,"attrs":2583,"content":2584},{"textAlign":139},[2585],{"text":2586,"type":75},"The recent carrier impersonation case is a reminder that cargo theft is evolving. Criminals are no longer trying to break into the supply chain. Increasingly, they are attempting to blend into it.",{"type":112,"attrs":2588,"content":2589},{"textAlign":139},[2590],{"text":2591,"type":75},"That places new importance on the yard.",{"type":112,"attrs":2593,"content":2594},{"textAlign":139},[2595],{"text":2596,"type":75},"Because when a fraudulent pickup occurs, the theft usually does not begin on the highway. It begins at the moment someone checks in, receives access, and leaves with freight they were never supposed to have.",{"type":112,"attrs":2598,"content":2599},{"textAlign":139},[2600],{"text":2601,"type":75},"The road may be where the load disappears.",{"type":112,"attrs":2603,"content":2604},{"textAlign":139},[2605],{"text":2606,"type":75},"But the yard is where the decision was made.",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[2609],"89f3c339-f4ad-4593-accc-39e8eebbfc7d",{"id":2611,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":2612,"copyright":18,"fieldtype":1105,"meta_data":2613,"is_external_url":49},187879930821311,"/storyblok/f/337048/2050x1288/cc16937dab/cargo-theft.png",{},{"id":2611,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":2612,"copyright":18,"fieldtype":1105,"meta_data":2615,"is_external_url":49},{},[],{"value":1934,"plugin":1635},"the-4-5-million-freight-theft-that-started-with-a-fake-identity","all-resources/the-4-5-million-freight-theft-that-started-with-a-fake-identity","2026-06-15",-2250,[],"7d4077f0-9d1b-4682-9baf-230ae4ba9432","2026-06-15T00:00:00.000Z",[],{"name":2627,"created_at":2628,"published_at":2629,"updated_at":2630,"id":2631,"uuid":2632,"content":2633,"slug":2907,"full_slug":2908,"sort_by_date":2909,"position":2910,"tag_list":2911,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":2912,"first_published_at":2913,"release_id":139,"lang":1161,"path":139,"alternates":2914,"default_full_slug":139,"translated_slugs":139},"The Driver Is Gone. The Yard Problem Isn't.","2026-06-08T19:08:31.377Z","2026-06-08T19:11:39.845Z","2026-06-08T19:11:39.862Z",185369032240974,"8642b1d1-1911-4ece-b6f8-05d63651fa50",{"_uid":2634,"body":2635,"link":2896,"title":2627,"author":2897,"excerpt":2641,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":2898,"seo_title":2627,"button_text":132,"cover_image":2900,"gated_asset":2904,"seo_noindex":49,"seo_description":2905,"background_color":2906,"featured_in_latest_news":49},"1e438777-3fb2-409f-93f7-5fb9244c724f",{"type":66,"content":2636},[2637,2642,2647,2652,2659,2664,2669,2674,2679,2684,2689,2694,2699,2704,2709,2714,2719,2724,2729,2734,2739,2744,2749,2754,2759,2764,2769,2774,2779,2784,2789,2794,2799,2804,2809,2814,2819,2824,2829,2834,2839,2844,2849,2854,2859,2864,2869,2874,2881,2886,2891],{"type":112,"attrs":2638,"content":2639},{"textAlign":139},[2640],{"text":2641,"type":75},"PepsiCo recently became the first major consumer goods company to deploy fully driverless trucks at scale, operating commercial routes without a human behind the wheel. The trucks are making deliveries to customers such as Walmart and Dollar General, achieving impressive levels of reliability and demonstrating just how quickly autonomous transportation is moving from experiment to reality.",{"type":112,"attrs":2643,"content":2644},{"textAlign":139},[2645],{"text":2646,"type":75},"For many, this feels like a glimpse into the future of logistics.",{"type":112,"attrs":2648,"content":2649},{"textAlign":139},[2650],{"text":2651,"type":75},"But there's an important question hiding behind the headlines:",{"type":112,"attrs":2653,"content":2654},{"textAlign":139},[2655],{"text":2656,"type":75,"marks":2657},"What happens when the truck arrives?",[2658],{"type":710},{"type":69,"attrs":2660,"content":2661},{"level":138,"textAlign":139},[2662],{"text":2663,"type":75},"The Autonomous Truck Era Has Arrived",{"type":112,"attrs":2665,"content":2666},{"textAlign":139},[2667],{"text":2668,"type":75},"For years, autonomous trucking has been treated as a distant possibility. The technology showed promise, but questions remained around safety, scalability, regulation, and operational viability.",{"type":112,"attrs":2670,"content":2671},{"textAlign":139},[2672],{"text":2673,"type":75},"Today, those questions are beginning to be answered.",{"type":112,"attrs":2675,"content":2676},{"textAlign":139},[2677],{"text":2678,"type":75},"Driverless trucks are no longer being tested in controlled environments. They are moving freight, serving customers, and becoming part of real supply chains.",{"type":112,"attrs":2680,"content":2681},{"textAlign":139},[2682],{"text":2683,"type":75},"The implications are enormous.",{"type":112,"attrs":2685,"content":2686},{"textAlign":139},[2687],{"text":2688,"type":75},"Autonomous trucks have the potential to reduce labor constraints, improve utilization, increase network flexibility, and keep goods moving around the clock. For an industry facing persistent driver shortages and growing pressure to move freight more efficiently, the appeal is obvious.",{"type":112,"attrs":2690,"content":2691},{"textAlign":139},[2692],{"text":2693,"type":75},"Yet transportation is only one piece of the logistics puzzle.",{"type":112,"attrs":2695,"content":2696},{"textAlign":139},[2697],{"text":2698,"type":75},"Because moving a trailer from Point A to Point B is not the same thing as moving it through a facility.",{"type":69,"attrs":2700,"content":2701},{"level":138,"textAlign":139},[2702],{"text":2703,"type":75},"The Last Hundred Yards",{"type":112,"attrs":2705,"content":2706},{"textAlign":139},[2707],{"text":2708,"type":75},"The logistics industry often focuses on what happens on the road or inside the warehouse.",{"type":112,"attrs":2710,"content":2711},{"textAlign":139},[2712],{"text":2713,"type":75},"But between those two environments sits one of the most operationally complex and overlooked areas in the supply chain: the yard.",{"type":112,"attrs":2715,"content":2716},{"textAlign":139},[2717],{"text":2718,"type":75},"Every trailer entering a facility must be checked in, identified, routed, parked, assigned, tracked, and eventually loaded or unloaded. Dozens, hundreds, or even thousands of trailer moves can take place every day within a single operation.",{"type":112,"attrs":2720,"content":2721},{"textAlign":139},[2722],{"text":2723,"type":75},"In many facilities, these processes are still surprisingly manual.",{"type":112,"attrs":2725,"content":2726},{"textAlign":139},[2727],{"text":2728,"type":75},"Gate personnel verify information by hand. Drivers wait in queues. Yard locations are updated manually. Teams rely on radio calls, spreadsheets, paper logs, and institutional knowledge to coordinate activity.",{"type":112,"attrs":2730,"content":2731},{"textAlign":139},[2732],{"text":2733,"type":75},"A driverless truck may be able to navigate highways autonomously, but it still needs instructions when it reaches the gate.",{"type":112,"attrs":2735,"content":2736},{"textAlign":139},[2737],{"text":2738,"type":75},"It still needs to know where to go.",{"type":112,"attrs":2740,"content":2741},{"textAlign":139},[2742],{"text":2743,"type":75},"It still needs a dock assignment.",{"type":112,"attrs":2745,"content":2746},{"textAlign":139},[2747],{"text":2748,"type":75},"It still needs to interact with the physical environment of the yard.",{"type":112,"attrs":2750,"content":2751},{"textAlign":139},[2752],{"text":2753,"type":75},"And that is where many supply chains continue to face bottlenecks.",{"type":69,"attrs":2755,"content":2756},{"level":138,"textAlign":139},[2757],{"text":2758,"type":75},"Autonomy Requires Coordination",{"type":112,"attrs":2760,"content":2761},{"textAlign":139},[2762],{"text":2763,"type":75},"One of the biggest misconceptions about automation is that individual technologies create autonomous operations on their own.",{"type":112,"attrs":2765,"content":2766},{"textAlign":139},[2767],{"text":2768,"type":75},"In reality, autonomy is a coordination problem.",{"type":112,"attrs":2770,"content":2771},{"textAlign":139},[2772],{"text":2773,"type":75},"A warehouse robot is only effective if it knows where inventory is located.",{"type":112,"attrs":2775,"content":2776},{"textAlign":139},[2777],{"text":2778,"type":75},"An autonomous truck is only effective if the destination facility can receive it efficiently.",{"type":112,"attrs":2780,"content":2781},{"textAlign":139},[2782],{"text":2783,"type":75},"Every automated system depends on accurate, real-time information about the physical world.",{"type":112,"attrs":2785,"content":2786},{"textAlign":139},[2787],{"text":2788,"type":75},"As more companies invest in autonomous vehicles, robotics, and AI-powered operations, the importance of the yard only increases.",{"type":112,"attrs":2790,"content":2791},{"textAlign":139},[2792],{"text":2793,"type":75},"The yard is where transportation meets warehousing.",{"type":112,"attrs":2795,"content":2796},{"textAlign":139},[2797],{"text":2798,"type":75},"It is where freight transitions between networks.",{"type":112,"attrs":2800,"content":2801},{"textAlign":139},[2802],{"text":2803,"type":75},"It is where delays become detention costs, missed appointments, congestion, and lost productivity.",{"type":112,"attrs":2805,"content":2806},{"textAlign":139},[2807],{"text":2808,"type":75},"And increasingly, it is where the next wave of logistics innovation will need to focus.",{"type":69,"attrs":2810,"content":2811},{"level":138,"textAlign":139},[2812],{"text":2813,"type":75},"Building the Infrastructure for Physical AI",{"type":112,"attrs":2815,"content":2816},{"textAlign":139},[2817],{"text":2818,"type":75},"The future of logistics will not be defined by a single breakthrough technology.",{"type":112,"attrs":2820,"content":2821},{"textAlign":139},[2822],{"text":2823,"type":75},"It will be defined by how well those technologies work together.",{"type":112,"attrs":2825,"content":2826},{"textAlign":139},[2827],{"text":2828,"type":75},"Autonomous trucks. Robotics. Computer vision. AI agents. Automated warehouses.",{"type":112,"attrs":2830,"content":2831},{"textAlign":139},[2832],{"text":2833,"type":75},"All of these systems require a shared understanding of what is happening in the physical world.",{"type":112,"attrs":2835,"content":2836},{"textAlign":139},[2837],{"text":2838,"type":75},"That visibility starts in the yard.",{"type":112,"attrs":2840,"content":2841},{"textAlign":139},[2842],{"text":2843,"type":75},"At Terminal Industries, we believe the yard is evolving from a disconnected operational space into a digitally orchestrated environment. Through AI, computer vision, and real-time yard intelligence, operators can gain the visibility and coordination required to support the next generation of logistics technologies.",{"type":112,"attrs":2845,"content":2846},{"textAlign":139},[2847],{"text":2848,"type":75},"Because the future is not simply about autonomous trucks.",{"type":112,"attrs":2850,"content":2851},{"textAlign":139},[2852],{"text":2853,"type":75},"It's about creating facilities that are ready to receive them.",{"type":69,"attrs":2855,"content":2856},{"level":138,"textAlign":139},[2857],{"text":2858,"type":75},"The Road Ahead",{"type":112,"attrs":2860,"content":2861},{"textAlign":139},[2862],{"text":2863,"type":75},"PepsiCo's deployment of driverless trucks marks an important milestone for the industry. It demonstrates that autonomous transportation is no longer a future concept. It's beginning to happen now.",{"type":112,"attrs":2865,"content":2866},{"textAlign":139},[2867],{"text":2868,"type":75},"But the lesson extends beyond trucking.",{"type":112,"attrs":2870,"content":2871},{"textAlign":139},[2872],{"text":2873,"type":75},"Every new wave of automation raises the same question:",{"type":112,"attrs":2875,"content":2876},{"textAlign":139},[2877],{"text":2878,"type":75,"marks":2879},"Can the rest of the operation keep up?",[2880],{"type":710},{"type":112,"attrs":2882,"content":2883},{"textAlign":139},[2884],{"text":2885,"type":75},"As logistics becomes increasingly autonomous, the companies that gain the greatest advantage won't be the ones that automate a single process.",{"type":112,"attrs":2887,"content":2888},{"textAlign":139},[2889],{"text":2890,"type":75},"They'll be the ones that connect the entire flow of goods, from the highway to the warehouse door.",{"type":112,"attrs":2892,"content":2893},{"textAlign":139},[2894],{"text":2895,"type":75},"And that journey passes through the yard.",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[2609],{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":2899},{},{"id":2901,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":2902,"copyright":18,"fieldtype":1105,"meta_data":2903,"is_external_url":49},185369604224446,"/storyblok/f/337048/1520x872/c718cc5dc1/truck.png",{},[],"Pepsi driverless trucks ",{"value":1934,"plugin":1635},"the-driver-is-gone-the-yard-problem-isn-t-","all-resources/the-driver-is-gone-the-yard-problem-isn-t-","2026-06-08",-2240,[],"90f0d373-9050-49ab-bd73-f44885478bba","2026-06-08T00:00:00.000Z",[],{"name":2916,"created_at":2917,"published_at":2918,"updated_at":2919,"id":2920,"uuid":2921,"content":2922,"slug":3101,"full_slug":3102,"sort_by_date":3103,"position":3104,"tag_list":3105,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":3106,"first_published_at":3107,"release_id":139,"lang":1161,"path":139,"alternates":3108,"default_full_slug":139,"translated_slugs":139},"Humanoid Robots Are Entering Logistics. But the Yard Still Has to Catch Up.","2026-05-31T19:36:14.474Z","2026-05-31T19:38:17.780Z","2026-05-31T19:38:17.797Z",182544689082663,"3cfaa232-e651-4e06-ba11-ad0f1a6cf39d",{"_uid":2923,"body":2924,"link":3091,"title":2916,"author":3092,"excerpt":2930,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":3093,"seo_title":2916,"button_text":132,"cover_image":3095,"gated_asset":3099,"seo_noindex":49,"seo_description":2916,"background_color":3100,"featured_in_latest_news":49},"c9498ca6-ff4e-4e1f-aa84-b6babe31e3dc",{"type":66,"content":2925},[2926,2931,2936,2941,2946,2951,2956,2961,2966,2971,2976,2981,2986,2991,2996,3001,3006,3011,3016,3021,3026,3031,3036,3041,3046,3051,3056,3061,3066,3071,3076,3081,3086],{"type":112,"attrs":2927,"content":2928},{"textAlign":139},[2929],{"text":2930,"type":75},"In the past week, Figure AI announced a commercial agreement with Catalyst Brands, the parent company of JCPenney, Aéropostale, and Brooks Brothers, to deploy humanoid robots into its distribution and logistics network. The initial rollout will begin at Catalyst’s Reno, Nevada Distribution Logistics Center, where the robots will focus on physically demanding supply chain tasks.",{"type":112,"attrs":2932,"content":2933},{"textAlign":139},[2934],{"text":2935,"type":75},"At the same time, China’s humanoid robotics market is accelerating quickly. Recent coverage has pointed to China’s push to mass produce lower cost humanoid robots for factories and warehouses, with some models reportedly priced far below traditional industrial robotics systems. TrendForce has also projected that China’s humanoid robot output will grow sharply in 2026 as the sector moves closer to commercialization.",{"type":112,"attrs":2937,"content":2938},{"textAlign":139},[2939],{"text":2940,"type":75},"The headline is easy to understand: robots are coming to logistics.",{"type":112,"attrs":2942,"content":2943},{"textAlign":139},[2944],{"text":2945,"type":75},"The harder question is whether logistics environments are actually ready for them.",{"type":112,"attrs":2947,"content":2948},{"textAlign":139},[2949],{"text":2950,"type":75},"Humanoid robots are often framed as the next labor breakthrough. They can sort, lift, move, pack, and eventually perform repetitive physical tasks that are difficult to staff and expensive to scale. That is a meaningful shift, especially in an industry where labor shortages, rising costs, and throughput pressure continue to challenge operators. Schaeffler, for example, recently announced plans with Humanoid to deploy between 1,000 and 2,000 humanoid robots across manufacturing sites by 2032.",{"type":112,"attrs":2952,"content":2953},{"textAlign":139},[2954],{"text":2955,"type":75},"But a robot does not operate in a vacuum.",{"type":112,"attrs":2957,"content":2958},{"textAlign":139},[2959],{"text":2960,"type":75},"It operates inside a physical system.",{"type":112,"attrs":2962,"content":2963},{"textAlign":139},[2964],{"text":2965,"type":75},"And that system has to know what is happening.",{"type":112,"attrs":2967,"content":2968},{"textAlign":139},[2969],{"text":2970,"type":75},"A humanoid robot can only be useful if the environment around it is coordinated. It needs accurate work instructions. It needs reliable inventory data. It needs to know where assets are, what needs to move, which dock is available, what trailer is arriving, and whether the physical world matches the system of record.",{"type":112,"attrs":2972,"content":2973},{"textAlign":139},[2974],{"text":2975,"type":75},"That is where the robotics conversation gets more complicated.",{"type":112,"attrs":2977,"content":2978},{"textAlign":139},[2979],{"text":2980,"type":75},"Most logistics automation stories focus on what happens inside the warehouse. Robots moving totes. Robots packing boxes. Robots supporting associates on the floor. But warehouses do not begin and end at the four walls of the building. Every automated warehouse still depends on trucks arriving, trailers being checked in, assets being located, docks being assigned, and yard moves happening on time.",{"type":112,"attrs":2982,"content":2983},{"textAlign":139},[2984],{"text":2985,"type":75},"If the warehouse becomes automated but the yard remains manual, the bottleneck does not disappear.",{"type":112,"attrs":2987,"content":2988},{"textAlign":139},[2989],{"text":2990,"type":75},"It simply moves outside.",{"type":112,"attrs":2992,"content":2993},{"textAlign":139},[2994],{"text":2995,"type":75},"This is the missing layer in the humanoid robotics conversation. The future of logistics will not be won by robots alone. It will be won by the systems that allow robots, humans, docks, trailers, gates, and transportation networks to operate from the same real time source of truth.",{"type":112,"attrs":2997,"content":2998},{"textAlign":139},[2999],{"text":3000,"type":75},"Think about the practical problem.",{"type":112,"attrs":3002,"content":3003},{"textAlign":139},[3004],{"text":3005,"type":75},"A humanoid robot may be able to sort or pack faster, but what happens if the trailer it needs is sitting in the wrong location? What happens if a driver checked in manually and the information was entered late? What happens if the warehouse believes a trailer is at Dock 12, but physically it is still waiting in the yard? What happens if detention time is building because the facility has no live visibility into what is actually happening outside?",{"type":112,"attrs":3007,"content":3008},{"textAlign":139},[3009],{"text":3010,"type":75},"In those moments, the robot is not the constraint.",{"type":112,"attrs":3012,"content":3013},{"textAlign":139},[3014],{"text":3015,"type":75},"The operating environment is.",{"type":112,"attrs":3017,"content":3018},{"textAlign":139},[3019],{"text":3020,"type":75},"That is why the next phase of logistics automation has to extend beyond warehouse robotics and into yard intelligence.",{"type":112,"attrs":3022,"content":3023},{"textAlign":139},[3024],{"text":3025,"type":75},"The yard is where the physical supply chain becomes visible or invisible. It is where trucks enter, trailers dwell, appointments collide with reality, dock schedules shift, and small delays compound into network wide inefficiency. For years, the yard has been treated as a gray zone between transportation and warehouse operations. But in an increasingly automated supply chain, that gray zone becomes a risk.",{"type":112,"attrs":3027,"content":3028},{"textAlign":139},[3029],{"text":3030,"type":75},"Robots need clean data.",{"type":112,"attrs":3032,"content":3033},{"textAlign":139},[3034],{"text":3035,"type":75},"AI needs physical visibility.",{"type":112,"attrs":3037,"content":3038},{"textAlign":139},[3039],{"text":3040,"type":75},"Automation needs orchestration.",{"type":112,"attrs":3042,"content":3043},{"textAlign":139},[3044],{"text":3045,"type":75},"And the yard is one of the most important places to get that right.",{"type":112,"attrs":3047,"content":3048},{"textAlign":139},[3049],{"text":3050,"type":75},"This is where computer vision and AI become essential. By using cameras and intelligent software to capture real time yard activity, logistics operators can create a live picture of what is actually happening on the ground. That means trailers can be identified, movements can be tracked, gate activity can be automated, and yard inventory can become accurate without relying on manual updates alone.",{"type":112,"attrs":3052,"content":3053},{"textAlign":139},[3054],{"text":3055,"type":75},"For Terminal, this is the central point.",{"type":112,"attrs":3057,"content":3058},{"textAlign":139},[3059],{"text":3060,"type":75},"The yard of the future is not just a more efficient version of today’s yard. It is the operational layer that makes advanced automation possible. A warehouse full of robots still needs accurate arrivals, real time trailer visibility, faster gate processing, smarter dock coordination, and a connected system of record that reflects the physical world.",{"type":112,"attrs":3062,"content":3063},{"textAlign":139},[3064],{"text":3065,"type":75},"Humanoid robots may be the shiny object in logistics right now.",{"type":112,"attrs":3067,"content":3068},{"textAlign":139},[3069],{"text":3070,"type":75},"But the real transformation is bigger than the robot.",{"type":112,"attrs":3072,"content":3073},{"textAlign":139},[3074],{"text":3075,"type":75},"It is the shift from disconnected physical operations to intelligent, AI powered execution across the entire facility. The companies that win will not just automate tasks. They will automate awareness. They will build logistics environments where humans, robots, and systems can all act on the same truth.",{"type":112,"attrs":3077,"content":3078},{"textAlign":139},[3079],{"text":3080,"type":75},"The humanoid robot race has started.",{"type":112,"attrs":3082,"content":3083},{"textAlign":139},[3084],{"text":3085,"type":75},"But before logistics can fully embrace robot workers, it has to solve something more foundational:",{"type":112,"attrs":3087,"content":3088},{"textAlign":139},[3089],{"text":3090,"type":75},"The yard has to become intelligent too.",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[2609],{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":3094},{},{"id":3096,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":3097,"copyright":18,"fieldtype":1105,"meta_data":3098,"is_external_url":49},122032251214763,"/storyblok/f/337048/2200x1466/bf6f79dc16/trailer-repair-depot.webp",{},[],{"value":1934,"plugin":1635},"humanoid-robots-are-entering-logistics-but-the-yard-still-has-to-catch-up-","all-resources/humanoid-robots-are-entering-logistics-but-the-yard-still-has-to-catch-up-","2026-06-01",-2230,[],"121c0290-fe41-4547-bc8b-ad9657e9dd83","2026-06-01T00:00:00.000Z",[],{"name":3110,"created_at":3111,"published_at":3112,"updated_at":3113,"id":3114,"uuid":3115,"content":3116,"slug":3370,"full_slug":3371,"sort_by_date":3372,"position":3373,"tag_list":3374,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":3375,"first_published_at":3376,"release_id":139,"lang":1161,"path":139,"alternates":3377,"default_full_slug":139,"translated_slugs":139},"The Autonomous Warehouse Has a Blind Spot: The Yard","2026-05-26T15:05:41.030Z","2026-05-26T15:07:29.388Z","2026-05-26T15:07:29.410Z",180708724899061,"0b736b2a-09d2-403a-8375-0b577006ca3a",{"_uid":3117,"body":3118,"link":3359,"title":3110,"author":3360,"excerpt":3361,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":3362,"seo_title":3110,"button_text":132,"cover_image":3364,"gated_asset":3368,"seo_noindex":49,"seo_description":3110,"background_color":3369,"featured_in_latest_news":49},"d4937fa5-77a3-4150-aae6-2526623ed901",{"type":66,"content":3119},[3120,3125,3130,3135,3140,3145,3156,3161,3166,3171,3176,3181,3186,3232,3237,3242,3247,3252,3257,3262,3267,3311,3316,3321,3326,3334,3339,3344,3349,3354],{"type":112,"attrs":3121,"content":3122},{"textAlign":139},[3123],{"text":3124,"type":75},"The race toward warehouse automation is accelerating fast.",{"type":112,"attrs":3126,"content":3127},{"textAlign":139},[3128],{"text":3129,"type":75},"According to recent Gartner predictions, by 2030, more than 50% of warehouse operations are expected to adopt some form of robotics or automation to support workload handling and fulfillment execution. Across the industry, companies are investing heavily in robotic picking systems, autonomous forklifts, AI-powered inventory management, and warehouse orchestration software as operators push for faster throughput, lower labor dependency, and greater operational resilience.",{"type":112,"attrs":3131,"content":3132},{"textAlign":139},[3133],{"text":3134,"type":75},"The message is clear: the warehouse is becoming autonomous.",{"type":112,"attrs":3136,"content":3137},{"textAlign":139},[3138],{"text":3139,"type":75},"But there’s one major problem.",{"type":112,"attrs":3141,"content":3142},{"textAlign":139},[3143],{"text":3144,"type":75},"Most supply chains are still treating the yard like a parking lot.",{"type":112,"attrs":3146,"content":3147},{"textAlign":139},[3148,3150,3154],{"text":3149,"type":75},"While billions are being poured into automating what happens ",{"text":3151,"type":75,"marks":3152},"inside",[3153],{"type":2107},{"text":3155,"type":75}," the four walls, many facilities still rely on manual check-ins, radio communication, disconnected systems, clipboards, spreadsheets, and limited visibility to manage the movement of trailers, drivers, and equipment outside the warehouse doors.",{"type":112,"attrs":3157,"content":3158},{"textAlign":139},[3159],{"text":3160,"type":75},"And that disconnect matters more than ever.",{"type":69,"attrs":3162,"content":3163},{"level":138,"textAlign":139},[3164],{"text":3165,"type":75},"Automation Moves Faster Than Bottlenecks",{"type":112,"attrs":3167,"content":3168},{"textAlign":139},[3169],{"text":3170,"type":75},"The more efficient a warehouse becomes, the more pressure it places on upstream and downstream operations.",{"type":112,"attrs":3172,"content":3173},{"textAlign":139},[3174],{"text":3175,"type":75},"A robotic warehouse capable of processing inventory faster than ever before still depends on trailers arriving at the correct dock, at the correct time, with the correct priority. If yard operations cannot coordinate that movement in real time, warehouse automation simply accelerates congestion.",{"type":112,"attrs":3177,"content":3178},{"textAlign":139},[3179],{"text":3180,"type":75},"In many cases, warehouse automation doesn’t eliminate operational friction. It exposes it.",{"type":112,"attrs":3182,"content":3183},{"textAlign":139},[3184],{"text":3185,"type":75},"A facility may reduce picking times by minutes, but still lose hours due to:",{"type":3187,"content":3188},"bullet_list",[3189,3197,3204,3211,3218,3225],{"type":3190,"content":3191},"list_item",[3192],{"type":112,"attrs":3193,"content":3194},{"textAlign":139},[3195],{"text":3196,"type":75},"trailer misplacement",{"type":3190,"content":3198},[3199],{"type":112,"attrs":3200,"content":3201},{"textAlign":139},[3202],{"text":3203,"type":75},"gate congestion",{"type":3190,"content":3205},[3206],{"type":112,"attrs":3207,"content":3208},{"textAlign":139},[3209],{"text":3210,"type":75},"detention delays",{"type":3190,"content":3212},[3213],{"type":112,"attrs":3214,"content":3215},{"textAlign":139},[3216],{"text":3217,"type":75},"poor dock coordination",{"type":3190,"content":3219},[3220],{"type":112,"attrs":3221,"content":3222},{"textAlign":139},[3223],{"text":3224,"type":75},"lack of real-time visibility",{"type":3190,"content":3226},[3227],{"type":112,"attrs":3228,"content":3229},{"textAlign":139},[3230],{"text":3231,"type":75},"disconnected yard workflows",{"type":112,"attrs":3233,"content":3234},{"textAlign":139},[3235],{"text":3236,"type":75},"The result is an increasingly common industry problem: highly advanced warehouse operations sitting behind inefficient yard execution.",{"type":69,"attrs":3238,"content":3239},{"level":138,"textAlign":139},[3240],{"text":3241,"type":75},"The Yard Is Becoming the Operational Control Layer",{"type":112,"attrs":3243,"content":3244},{"textAlign":139},[3245],{"text":3246,"type":75},"Historically, supply chain technology investment has focused heavily on Transportation Management Systems (TMS) and Warehouse Management Systems (WMS). The yard, despite connecting both environments physically and operationally, has often remained under-digitized.",{"type":112,"attrs":3248,"content":3249},{"textAlign":139},[3250],{"text":3251,"type":75},"That is starting to change.",{"type":112,"attrs":3253,"content":3254},{"textAlign":139},[3255],{"text":3256,"type":75},"As automation adoption increases, operators are recognizing that the yard is no longer a secondary operational layer. It is becoming the coordination engine that determines whether autonomous systems can operate efficiently at scale.",{"type":112,"attrs":3258,"content":3259},{"textAlign":139},[3260],{"text":3261,"type":75},"Robots can automate fulfillment.",{"type":112,"attrs":3263,"content":3264},{"textAlign":139},[3265],{"text":3266,"type":75},"But they cannot solve:",{"type":3187,"content":3268},[3269,3276,3283,3290,3297,3304],{"type":3190,"content":3270},[3271],{"type":112,"attrs":3272,"content":3273},{"textAlign":139},[3274],{"text":3275,"type":75},"trailer orchestration",{"type":3190,"content":3277},[3278],{"type":112,"attrs":3279,"content":3280},{"textAlign":139},[3281],{"text":3282,"type":75},"gate throughput",{"type":3190,"content":3284},[3285],{"type":112,"attrs":3286,"content":3287},{"textAlign":139},[3288],{"text":3289,"type":75},"yard congestion",{"type":3190,"content":3291},[3292],{"type":112,"attrs":3293,"content":3294},{"textAlign":139},[3295],{"text":3296,"type":75},"spotter coordination",{"type":3190,"content":3298},[3299],{"type":112,"attrs":3300,"content":3301},{"textAlign":139},[3302],{"text":3303,"type":75},"real-time execution decisions",{"type":3190,"content":3305},[3306],{"type":112,"attrs":3307,"content":3308},{"textAlign":139},[3309],{"text":3310,"type":75},"physical flow synchronization across the site",{"type":112,"attrs":3312,"content":3313},{"textAlign":139},[3314],{"text":3315,"type":75},"Those challenges increasingly require a new category of infrastructure built around visibility, orchestration, and execution intelligence.",{"type":69,"attrs":3317,"content":3318},{"level":138,"textAlign":139},[3319],{"text":3320,"type":75},"Why the Future of Automation Extends Beyond the Warehouse",{"type":112,"attrs":3322,"content":3323},{"textAlign":139},[3324],{"text":3325,"type":75},"The industry conversation around automation often focuses on what is visible: robotic arms, autonomous forklifts, drones, humanoids, and AI-powered warehouse systems.",{"type":112,"attrs":3327,"content":3328},{"textAlign":139},[3329,3331,3332],{"text":3330,"type":75},"But the facilities that achieve the greatest operational gains in the next decade will likely be the ones that solve something less visible:",{"type":618},{"text":3333,"type":75},"the coordination of physical operations across the entire site.",{"type":112,"attrs":3335,"content":3336},{"textAlign":139},[3337],{"text":3338,"type":75},"That includes the yard.",{"type":112,"attrs":3340,"content":3341},{"textAlign":139},[3342],{"text":3343,"type":75},"Because in reality, the warehouse and yard are not separate operational environments anymore. They are deeply interconnected systems. When one moves faster, the other must evolve alongside it.",{"type":112,"attrs":3345,"content":3346},{"textAlign":139},[3347],{"text":3348,"type":75},"The future of autonomous logistics will not be defined solely by what happens inside the warehouse walls.",{"type":112,"attrs":3350,"content":3351},{"textAlign":139},[3352],{"text":3353,"type":75},"It will be defined by how intelligently the entire operation moves together.",{"type":112,"attrs":3355,"content":3356},{"textAlign":139},[3357],{"text":3358,"type":75},"And increasingly, that future starts in the yard.",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[2609],"The race toward warehouse automation is accelerating fast.\n\nAccording to recent Gartner predictions, by 2030, more than 50% of warehouse operations are expected to adopt some form of robotics or automation to support workload handling and fulfillment execution. Across the industry, companies are investing heavily in robotic picking systems, autonomous forklifts, AI-powered inventory management, and warehouse orchestration software as o",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":3363},{},{"id":3365,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":3366,"copyright":18,"fieldtype":1105,"meta_data":3367,"is_external_url":49},120978580976576,"/storyblok/f/337048/768x432/ce73b10067/gate-entry.jpg",{},[],{"value":1934,"plugin":1635},"the-autonomous-warehouse-has-a-blind-spot-the-yard","all-resources/the-autonomous-warehouse-has-a-blind-spot-the-yard","2026-05-26",-2220,[],"4b3828b4-e177-45b4-8dd5-3ad9e67e0d44","2026-05-26T00:00:00.000Z",[],{"name":3379,"created_at":3380,"published_at":3381,"updated_at":3382,"id":3383,"uuid":3384,"content":3385,"slug":3401,"full_slug":3402,"sort_by_date":139,"position":3403,"tag_list":3404,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":3405,"first_published_at":3406,"release_id":139,"lang":1161,"path":139,"alternates":3407,"default_full_slug":139,"translated_slugs":139},"contact us interactive survey","2026-05-12T20:08:04.783Z","2026-05-12T20:11:07.979Z","2026-05-12T20:11:07.992Z",175828520114411,"3af37708-5188-42ed-ba8c-be3a08da1e4c",{"_uid":3386,"body":3387,"link":3390,"title":3391,"author":3392,"excerpt":18,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":3393,"seo_title":18,"button_text":132,"cover_image":3395,"gated_asset":3399,"seo_noindex":49,"seo_description":18,"background_color":3400,"featured_in_latest_news":49},"bebcf9b8-c78e-4bc4-a681-1af69be86560",{"type":66,"content":3388},[3389],{"type":112},{"id":692,"url":18,"linktype":19,"fieldtype":20,"cached_url":693},"Explore insights from 2000+ operations leaders on what's working, what's breaking, and where teams are investing ",[2609],{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":3394},{},{"id":3396,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":3397,"copyright":18,"fieldtype":1105,"meta_data":3398,"is_external_url":49},175828854099130,"/storyblok/f/337048/1260x1420/9bdfe1ff72/i.png",{},[],{"value":1934,"plugin":1635},"contact-us-interactive-survey","all-resources/contact-us-interactive-survey",-2210,[],"717109cb-25bd-4a9e-9346-7b1652a39b9a","2026-05-12T20:10:15.239Z",[],{"name":3409,"created_at":3410,"published_at":3411,"updated_at":3412,"id":3413,"uuid":3414,"content":3415,"slug":3517,"full_slug":3518,"sort_by_date":3519,"position":3520,"tag_list":3521,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":3522,"first_published_at":3523,"release_id":139,"lang":1161,"path":139,"alternates":3524,"default_full_slug":139,"translated_slugs":139},"Automation Isn’t the Hard Part Anymore","2026-05-11T18:01:02.684Z","2026-05-11T18:06:35.169Z","2026-05-11T18:06:35.203Z",175443405596689,"99d45b24-8d8b-4a54-a66b-591853172901",{"_uid":3416,"body":3417,"link":3507,"title":3409,"author":3508,"excerpt":3423,"category":1621,"is_gated":49,"subtitle":3501,"component":1623,"seo_image":3509,"seo_title":3409,"button_text":132,"cover_image":3511,"gated_asset":3515,"seo_noindex":49,"seo_description":3501,"background_color":3516,"featured_in_latest_news":49},"4265a463-0374-488a-8664-e28ce28c0a41",{"type":66,"content":3418},[3419,3424,3429,3434,3439,3444,3449,3454,3462,3467,3472,3477,3482,3487,3492,3497,3502],{"type":112,"attrs":3420,"content":3421},{"textAlign":139},[3422],{"text":3423,"type":75},"For years, supply chain innovation has been defined by a race toward automation. Companies invested heavily in robotics, sensors, AI tools, autonomous equipment, and warehouse modernization initiatives, all with the promise of faster operations and greater efficiency.",{"type":112,"attrs":3425,"content":3426},{"textAlign":139},[3427],{"text":3428,"type":75},"But a recent announcement from Procter & Gamble signals something bigger. The industry is entering a new phase.",{"type":112,"attrs":3430,"content":3431},{"textAlign":139},[3432],{"text":3433,"type":75},"Last week, P&G announced it is scaling its “Supply Chain 3.0” initiative across the organization after years spent building the infrastructure behind it. The company highlighted major advancements across automation, autonomous loading and unloading, systems integration, and even unstaffed overnight operations. More importantly, P&G emphasized that the real breakthrough was not a single technology. It was the years spent building the underlying platforms and operational capabilities required to make all of these systems work together.",{"type":112,"attrs":3435,"content":3436},{"textAlign":139},[3437],{"text":3438,"type":75},"That distinction matters.",{"type":112,"attrs":3440,"content":3441},{"textAlign":139},[3442],{"text":3443,"type":75},"Because increasingly, automation itself is no longer the hardest problem in logistics.",{"type":112,"attrs":3445,"content":3446},{"textAlign":139},[3447],{"text":3448,"type":75},"Orchestration is.",{"type":112,"attrs":3450,"content":3451},{"textAlign":139},[3452],{"text":3453,"type":75},"The industry has spent the last decade deploying point solutions into warehouses, transportation networks, and fulfillment operations. But many facilities still operate with fragmented systems, disconnected workflows, and limited coordination between physical operations and digital intelligence. In many cases, companies have modernized individual pieces of the supply chain without creating a connected operational environment around them.",{"type":112,"attrs":3455,"content":3456},{"textAlign":139},[3457,3459,3460],{"text":3458,"type":75},"The result is an operational paradox:",{"type":618},{"text":3461,"type":75},"more technology, but not always more flow.",{"type":112,"attrs":3463,"content":3464},{"textAlign":139},[3465],{"text":3466,"type":75},"This is especially true in the yard.",{"type":112,"attrs":3468,"content":3469},{"textAlign":139},[3470],{"text":3471,"type":75},"The yard sits at the intersection of warehouse operations, transportation, labor management, scheduling, trailer movements, gate operations, and increasingly autonomous systems. It is one of the most operationally dense environments in the supply chain, yet historically one of the least digitized.",{"type":112,"attrs":3473,"content":3474},{"textAlign":139},[3475],{"text":3476,"type":75},"As companies move toward autonomous warehouses and AI-driven logistics environments, the yard can no longer operate as a disconnected buffer between systems. It must become part of the orchestration layer itself.",{"type":112,"attrs":3478,"content":3479},{"textAlign":139},[3480],{"text":3481,"type":75},"That is where the industry is heading now.",{"type":112,"attrs":3483,"content":3484},{"textAlign":139},[3485],{"text":3486,"type":75},"Not toward isolated automation, but toward connected operational ecosystems capable of coordinating movement, resources, assets, and decisions in real time.",{"type":112,"attrs":3488,"content":3489},{"textAlign":139},[3490],{"text":3491,"type":75},"The next generation of supply chain infrastructure will not simply observe operations. It will coordinate them.",{"type":112,"attrs":3493,"content":3494},{"textAlign":139},[3495],{"text":3496,"type":75},"And that coordination increasingly depends on having real-time visibility into the physical world itself. Computer vision, AI, and operational intelligence are becoming foundational infrastructure for enabling physical AI across logistics environments, especially in the yard, where movement and execution collide every minute of the day.",{"type":112,"attrs":3498,"content":3499},{"textAlign":139},[3500],{"text":3501,"type":75},"P&G’s announcement is a reminder that the future of logistics will not be defined by who installs the most automation.",{"type":112,"attrs":3503,"content":3504},{"textAlign":139},[3505],{"text":3506,"type":75},"It will be defined by who can orchestrate it.",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[2609],{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":3510},{},{"id":3512,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":3513,"copyright":18,"fieldtype":1105,"meta_data":3514,"is_external_url":49},175444262366105,"/storyblok/f/337048/1638x1076/1ce8aa1225/truck.png",{},[],{"value":1934,"plugin":1635},"automation-isnt-the-hard-part-anymore","all-resources/automation-isnt-the-hard-part-anymore","2026-05-11",-2190,[],"a4a06f15-183b-45ed-b135-fa401cd0cf18","2026-05-11T00:00:00.000Z",[],{"name":3526,"created_at":3527,"published_at":3528,"updated_at":3529,"id":3530,"uuid":3531,"content":3532,"slug":3856,"full_slug":3857,"sort_by_date":3858,"position":3859,"tag_list":3860,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":3861,"first_published_at":3862,"release_id":139,"lang":1161,"path":139,"alternates":3863,"default_full_slug":139,"translated_slugs":139},"Amazon Just Turned Its Supply Chain Into a Product. Here’s What That Means for the Yard","2026-05-04T17:21:41.297Z","2026-05-04T22:36:44.210Z","2026-05-04T22:36:44.225Z",172956472547585,"a200535f-824a-4510-81b0-ad2e524ce609",{"_uid":3533,"body":3534,"link":3846,"title":3526,"author":3847,"excerpt":18,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":3848,"seo_title":3526,"button_text":132,"cover_image":3850,"gated_asset":3854,"seo_noindex":49,"seo_description":3526,"background_color":3855,"featured_in_latest_news":49},"7283e940-5398-4412-a408-21a05d3224c9",{"type":66,"content":3535},[3536,3541,3546,3551,3556,3562,3567,3572,3577,3582,3587,3592,3597,3602,3607,3612,3617,3622,3627,3632,3637,3642,3647,3670,3675,3680,3685,3690,3695,3700,3705,3710,3715,3720,3725,3748,3753,3758,3763,3768,3773,3778,3783,3806,3811,3816,3821,3826,3831,3836,3841],{"type":112,"attrs":3537,"content":3538},{"textAlign":139},[3539],{"text":3540,"type":75},"For years, Amazon has been quietly building one of the most sophisticated logistics networks in the world. This week, it made something clear: that network is no longer just a competitive advantage. It is now a product.",{"type":112,"attrs":3542,"content":3543},{"textAlign":139},[3544],{"text":3545,"type":75},"With the launch of Amazon’s end to end supply chain services offering, the company is opening its logistics infrastructure to other businesses. Freight, warehousing, fulfillment, and delivery are being bundled into a single, integrated system that companies can plug into.",{"type":112,"attrs":3547,"content":3548},{"textAlign":139},[3549],{"text":3550,"type":75},"This is not just an expansion. It is a shift in how logistics is defined.",{"type":112,"attrs":3552,"content":3553},{"textAlign":139},[3554],{"text":3555,"type":75},"Amazon is doing to supply chain what it did to cloud computing with AWS. It is taking a complex internal system, refining it, and offering it externally as a platform.",{"type":69,"attrs":3557,"content":3559},{"level":3558,"textAlign":139},3,[3560],{"text":3561,"type":75},"The Shift from Operators to Orchestrators",{"type":112,"attrs":3563,"content":3564},{"textAlign":139},[3565],{"text":3566,"type":75},"Historically, logistics has been asset driven. Companies competed based on the number of trucks they owned, the size of their warehouses, or the reach of their delivery networks.",{"type":112,"attrs":3568,"content":3569},{"textAlign":139},[3570],{"text":3571,"type":75},"That model is changing.",{"type":112,"attrs":3573,"content":3574},{"textAlign":139},[3575],{"text":3576,"type":75},"The next generation of supply chain leaders will not be defined by the assets they own, but by the systems they operate. The advantage is moving toward those who can coordinate, optimize, and orchestrate across an increasingly complex network.",{"type":112,"attrs":3578,"content":3579},{"textAlign":139},[3580],{"text":3581,"type":75},"Amazon’s move signals that the future of logistics is not just about moving goods efficiently. It is about controlling the system that determines how those goods move.",{"type":69,"attrs":3583,"content":3584},{"level":3558,"textAlign":139},[3585],{"text":3586,"type":75},"The Hidden Dependency in Every Logistics Platform",{"type":112,"attrs":3588,"content":3589},{"textAlign":139},[3590],{"text":3591,"type":75},"There is a critical layer in the supply chain that often goes overlooked in conversations about innovation.",{"type":112,"attrs":3593,"content":3594},{"textAlign":139},[3595],{"text":3596,"type":75},"The yard.",{"type":112,"attrs":3598,"content":3599},{"textAlign":139},[3600],{"text":3601,"type":75},"Every platform, no matter how advanced, depends on the physical movement of trailers in and out of facilities. Goods do not move directly from warehouse to truck to customer in a seamless flow. They pass through yards where trailers are staged, assigned, located, and transferred.",{"type":112,"attrs":3603,"content":3604},{"textAlign":139},[3605],{"text":3606,"type":75},"This is where coordination becomes real.",{"type":112,"attrs":3608,"content":3609},{"textAlign":139},[3610],{"text":3611,"type":75},"If a trailer is not where it is supposed to be, the downstream system breaks. Warehouse operations stall. Drivers wait. Schedules slip. Even the most advanced planning systems cannot compensate for a lack of real time execution on the ground.",{"type":112,"attrs":3613,"content":3614},{"textAlign":139},[3615],{"text":3616,"type":75},"In many operations today, the yard is still managed through manual processes, fragmented systems, and delayed information.",{"type":112,"attrs":3618,"content":3619},{"textAlign":139},[3620],{"text":3621,"type":75},"That creates a gap.",{"type":69,"attrs":3623,"content":3624},{"level":3558,"textAlign":139},[3625],{"text":3626,"type":75},"Why the Yard Becomes the Bottleneck",{"type":112,"attrs":3628,"content":3629},{"textAlign":139},[3630],{"text":3631,"type":75},"As supply chains become more connected and more platform driven, the tolerance for inefficiency decreases.",{"type":112,"attrs":3633,"content":3634},{"textAlign":139},[3635],{"text":3636,"type":75},"In a world where logistics is sold as a service, consistency matters. Visibility matters. Execution matters.",{"type":112,"attrs":3638,"content":3639},{"textAlign":139},[3640],{"text":3641,"type":75},"The yard is where all three are tested.",{"type":112,"attrs":3643,"content":3644},{"textAlign":139},[3645],{"text":3646,"type":75},"It is the point where:",{"type":3187,"content":3648},[3649,3656,3663],{"type":3190,"content":3650},[3651],{"type":112,"attrs":3652,"content":3653},{"textAlign":139},[3654],{"text":3655,"type":75},"transportation meets warehousing",{"type":3190,"content":3657},[3658],{"type":112,"attrs":3659,"content":3660},{"textAlign":139},[3661],{"text":3662,"type":75},"planning meets execution",{"type":3190,"content":3664},[3665],{"type":112,"attrs":3666,"content":3667},{"textAlign":139},[3668],{"text":3669,"type":75},"digital systems meet physical reality",{"type":112,"attrs":3671,"content":3672},{"textAlign":139},[3673],{"text":3674,"type":75},"And it is also one of the least modernized parts of the operation.",{"type":112,"attrs":3676,"content":3677},{"textAlign":139},[3678],{"text":3679,"type":75},"Companies have invested heavily in warehouse management systems and transportation management systems. These systems are powerful, but they rely on the yard to execute what they plan.",{"type":112,"attrs":3681,"content":3682},{"textAlign":139},[3683],{"text":3684,"type":75},"When the yard lacks visibility or coordination, the entire system becomes less reliable.",{"type":69,"attrs":3686,"content":3687},{"level":3558,"textAlign":139},[3688],{"text":3689,"type":75},"The Infrastructure Behind the Platform",{"type":112,"attrs":3691,"content":3692},{"textAlign":139},[3693],{"text":3694,"type":75},"Amazon’s new offering works because it has spent years building not just physical infrastructure, but operational control across its network.",{"type":112,"attrs":3696,"content":3697},{"textAlign":139},[3698],{"text":3699,"type":75},"For companies looking to compete or integrate into this new model, the question becomes:",{"type":112,"attrs":3701,"content":3702},{"textAlign":139},[3703],{"text":3704,"type":75},"How do you ensure your operations can meet the same standard of coordination and execution?",{"type":112,"attrs":3706,"content":3707},{"textAlign":139},[3708],{"text":3709,"type":75},"This is where the yard becomes a strategic priority, not just an operational afterthought.",{"type":69,"attrs":3711,"content":3712},{"level":3558,"textAlign":139},[3713],{"text":3714,"type":75},"The Role of a Yard Operating System",{"type":112,"attrs":3716,"content":3717},{"textAlign":139},[3718],{"text":3719,"type":75},"To support a platform driven supply chain, the yard needs to function as an integrated part of the system.",{"type":112,"attrs":3721,"content":3722},{"textAlign":139},[3723],{"text":3724,"type":75},"That requires:",{"type":3187,"content":3726},[3727,3734,3741],{"type":3190,"content":3728},[3729],{"type":112,"attrs":3730,"content":3731},{"textAlign":139},[3732],{"text":3733,"type":75},"real time visibility into assets and movements",{"type":3190,"content":3735},[3736],{"type":112,"attrs":3737,"content":3738},{"textAlign":139},[3739],{"text":3740,"type":75},"coordinated workflows across teams and systems",{"type":3190,"content":3742},[3743],{"type":112,"attrs":3744,"content":3745},{"textAlign":139},[3746],{"text":3747,"type":75},"the ability to adapt dynamically as conditions change",{"type":112,"attrs":3749,"content":3750},{"textAlign":139},[3751],{"text":3752,"type":75},"This is the role of a Yard Operating System.",{"type":112,"attrs":3754,"content":3755},{"textAlign":139},[3756],{"text":3757,"type":75},"Instead of treating the yard as a separate environment, it becomes a connected layer that links transportation, warehouse operations, and planning systems into a single flow.",{"type":69,"attrs":3759,"content":3760},{"level":3558,"textAlign":139},[3761],{"text":3762,"type":75},"Why This Matters Now",{"type":112,"attrs":3764,"content":3765},{"textAlign":139},[3766],{"text":3767,"type":75},"Amazon’s move accelerates a broader trend. Supply chains are becoming more interconnected, more data driven, and more performance sensitive.",{"type":112,"attrs":3769,"content":3770},{"textAlign":139},[3771],{"text":3772,"type":75},"As that happens, gaps in execution become more visible.",{"type":112,"attrs":3774,"content":3775},{"textAlign":139},[3776],{"text":3777,"type":75},"The yard is one of the largest of those gaps.",{"type":112,"attrs":3779,"content":3780},{"textAlign":139},[3781],{"text":3782,"type":75},"Companies that address it will be better positioned to:",{"type":3187,"content":3784},[3785,3792,3799],{"type":3190,"content":3786},[3787],{"type":112,"attrs":3788,"content":3789},{"textAlign":139},[3790],{"text":3791,"type":75},"reduce delays and idle time",{"type":3190,"content":3793},[3794],{"type":112,"attrs":3795,"content":3796},{"textAlign":139},[3797],{"text":3798,"type":75},"improve asset utilization",{"type":3190,"content":3800},[3801],{"type":112,"attrs":3802,"content":3803},{"textAlign":139},[3804],{"text":3805,"type":75},"increase reliability across their network",{"type":112,"attrs":3807,"content":3808},{"textAlign":139},[3809],{"text":3810,"type":75},"Those that do not will find it harder to keep up in a system where expectations are rising.",{"type":69,"attrs":3812,"content":3813},{"level":3558,"textAlign":139},[3814],{"text":3815,"type":75},"Bringing It Together",{"type":112,"attrs":3817,"content":3818},{"textAlign":139},[3819],{"text":3820,"type":75},"Amazon has shown what is possible when a supply chain is fully integrated and orchestrated.",{"type":112,"attrs":3822,"content":3823},{"textAlign":139},[3824],{"text":3825,"type":75},"But even the most advanced platforms depend on what happens at the ground level.",{"type":112,"attrs":3827,"content":3828},{"textAlign":139},[3829],{"text":3830,"type":75},"The yard is where strategy becomes execution.",{"type":112,"attrs":3832,"content":3833},{"textAlign":139},[3834],{"text":3835,"type":75},"As logistics continues to evolve into a service and a platform, the operations that win will be the ones that can coordinate every layer of the system, including the one that has been historically overlooked.",{"type":112,"attrs":3837,"content":3838},{"textAlign":139},[3839],{"text":3840,"type":75},"Because you cannot sell the supply chain as a service if the yard is still operating in the past.",{"type":112,"attrs":3842,"content":3843},{"textAlign":139},[3844],{"text":3845,"type":75},"And the future of logistics will be built by those who bring it into the system.",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[2609],{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":3849},{},{"id":3851,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":3852,"copyright":18,"fieldtype":1105,"meta_data":3853,"is_external_url":49},172956996306361,"/storyblok/f/337048/2156x1220/c449b64972/amazon.png",{},[],{"value":1934,"plugin":1635},"amazon-just-turned-its-supply-chain-into-a-product-here-s-what-that-means-for-the-yard","all-resources/amazon-just-turned-its-supply-chain-into-a-product-here-s-what-that-means-for-the-yard","2026-05-04",-2170,[],"e49c8621-5e13-46ef-bdae-82b9289508e2","2026-05-04T00:00:00.000Z",[],{"name":3865,"created_at":3866,"published_at":3867,"updated_at":3868,"id":3869,"uuid":3870,"content":3871,"slug":3951,"full_slug":3952,"sort_by_date":3953,"position":3954,"tag_list":3955,"is_startpage":49,"parent_id":1640,"meta_data":139,"group_id":3956,"first_published_at":3957,"release_id":139,"lang":1161,"path":139,"alternates":3958,"default_full_slug":139,"translated_slugs":139},"The Sky Just Opened. Logistics Didn’t Stay on the Ground.","2026-04-27T17:53:41.690Z","2026-04-27T17:58:45.186Z","2026-04-27T17:58:45.204Z",170487077670418,"2bb319bb-3249-44f6-871d-9f4cf6ae4662",{"_uid":3872,"body":3873,"link":3940,"title":3865,"author":3941,"excerpt":3942,"category":1621,"is_gated":49,"subtitle":18,"component":1623,"seo_image":3943,"seo_title":18,"button_text":132,"cover_image":3945,"gated_asset":3949,"seo_noindex":49,"seo_description":18,"background_color":3950,"featured_in_latest_news":49},"81477b05-5e5c-46b8-9ebc-dee49b6c95dd",{"type":66,"content":3874},[3875,3880,3885,3890,3895,3900,3905,3910,3915,3920,3925,3930,3935],{"type":112,"attrs":3876,"content":3877},{"textAlign":139},[3878],{"text":3879,"type":75},"On April 27, 2026, a meaningful shift in transportation began to take shape over New York City. Joby Aviation launched a week long flight campaign, operating real electric air taxi routes between JFK and Manhattan. What typically takes over an hour by car was completed in under ten minutes by air, demonstrating that eVTOL technology has moved beyond concept and into real world execution.",{"type":112,"attrs":3881,"content":3882},{"textAlign":139},[3883],{"text":3884,"type":75},"This was not a controlled demonstration or a prototype test. The flights operated within existing aviation systems, integrating with FAA-regulated airspace and connecting to active heliports across the city. At the same time, infrastructure development is accelerating in parallel, with long term plans underway to electrify heliports and convert them into scalable vertiports capable of supporting continuous operations. The Port Authority’s reported $45 billion vision for vertiport infrastructure at major hubs like JFK and Newark signals that this is being treated as foundational, not experimental.",{"type":112,"attrs":3886,"content":3887},{"textAlign":139},[3888],{"text":3889,"type":75},"While much of the attention is focused on passenger mobility, the broader implication sits within logistics. This moment represents the early stages of what can be described as three-dimensional logistics, where transportation is no longer constrained to ground movement alone.",{"type":112,"attrs":3891,"content":3892},{"textAlign":139},[3893],{"text":3894,"type":75},"Historically, supply chains have operated within a two-dimensional framework, with trucks moving horizontally across roads while goods are staged and processed across flat yards. Every optimization, from routing to scheduling, has been built around this limitation. With eVTOL aircraft entering the system, that constraint begins to dissolve, allowing cargo to move above congestion instead of through it and enabling high priority goods to transition directly into an aerial layer of the network.",{"type":112,"attrs":3896,"content":3897},{"textAlign":139},[3898],{"text":3899,"type":75},"In practical terms, this introduces a new type of flow in which cargo can arrive at a port or distribution center, be processed through the yard, and then transition vertically into an air based network without ever entering traditional road congestion. Early pilot programs and partnerships across aviation, logistics, and mobility companies suggest that these systems are being designed to integrate with existing infrastructure rather than replace it, creating a multi-layered transportation model.",{"type":112,"attrs":3901,"content":3902},{"textAlign":139},[3903],{"text":3904,"type":75},"However, this shift does not eliminate existing challenges. It redefines them.",{"type":112,"attrs":3906,"content":3907},{"textAlign":139},[3908],{"text":3909,"type":75},"Even in a vertically integrated system, every asset still needs to be identified, staged, prioritized, and routed before it moves, and that responsibility continues to sit within the yard. As vertical transport becomes viable, the complexity of yard operations increases significantly because facilities must now coordinate timing across ground and air simultaneously. This includes aligning cargo readiness with air slot availability, dynamically prioritizing loads based on downstream constraints, and orchestrating movements to ensure seamless transfers between modes.",{"type":112,"attrs":3911,"content":3912},{"textAlign":139},[3913],{"text":3914,"type":75},"This is where the conversation moves from transportation to orchestration, and where Terminal becomes directly relevant.",{"type":112,"attrs":3916,"content":3917},{"textAlign":139},[3918],{"text":3919,"type":75},"Terminal Industries is building the software layer designed for exactly this kind of complexity. In a world where logistics expands beyond flat surfaces, a Yard Operating System cannot simply track assets; it must actively coordinate them. Terminal’s approach centers on turning the yard into a real-time decision engine, where every movement is structured, prioritized, and executed through systems like Missions™ that orchestrate tasks across people, equipment, and now, increasingly, infrastructure layers.",{"type":112,"attrs":3921,"content":3922},{"textAlign":139},[3923],{"text":3924,"type":75},"In a future where a container may need to move from a gate to a staging area and then immediately to a vertical transfer point for an eVTOL departure, timing is no longer flexible. It becomes precise, synchronized, and dependent on multiple systems operating in parallel. Terminal’s model is built around this kind of execution, where workflows are not reactive but dynamically coordinated in real time.",{"type":112,"attrs":3926,"content":3927},{"textAlign":139},[3928],{"text":3929,"type":75},"The concept of the yard as a static holding space is beginning to break down, and in its place a more dynamic model is emerging where the yard functions as a central coordination layer within a larger, multi-dimensional network. As infrastructure evolves to support vertical movement, the effectiveness of that system will depend on how well the yard can manage and execute these increasingly complex flows.",{"type":112,"attrs":3931,"content":3932},{"textAlign":139},[3933],{"text":3934,"type":75},"The introduction of eVTOL technology and vertiport infrastructure marks the beginning of a new phase in logistics. While the aircraft represent a visible and compelling innovation, the underlying transformation will be driven by how goods are managed before they ever leave the ground.",{"type":112,"attrs":3936,"content":3937},{"textAlign":139},[3938],{"text":3939,"type":75},"As transportation expands into the vertical dimension, the yard becomes the system that determines whether that speed can actually be realized.",{"id":18,"url":18,"linktype":19,"fieldtype":20,"cached_url":18},[2609],"Joby Aviation launched a week-long flight campaign, running real, point-to-point electric air taxi routes between JFK and Manhattan. What used to take over an hour on the ground now takes under 10 minutes in the air.",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":3944},{},{"id":3946,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":3947,"copyright":18,"fieldtype":1105,"meta_data":3948,"is_external_url":49},170488273509153,"/storyblok/f/337048/860x480/ab2387730e/evtol.png",{},[],{"value":1934,"plugin":1635},"the-sky-just-opened-logistics-didn-t-stay-on-the-ground-","all-resources/the-sky-just-opened-logistics-didn-t-stay-on-the-ground-","2026-04-27",-2140,[],"231953ec-549e-403c-ba8e-895cd8319f95","2026-04-27T00:00:00.000Z",[],130,12,["Reactive",3962],{"$spage-header-visibility":1161,"$ssite-config":3963},{"_priority":3964,"env":3967,"name":3968,"url":3969},{"name":3965,"env":3966,"url":3965},-3,-15,"produc