1352,"show_bottom_extensions":25},"bfa97d3c-522b-41f2-ae20-f2aab048b3a1",[1247,1265,1278,1291,1304,1317],{"_uid":1248,"type":18,"image":1249,"heading":1251,"component":1252,"description":1253},"2c43224c-2084-4263-af3e-12d505d144c2",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"filename":139,"copyright":139,"fieldtype":1105,"meta_data":1250,"is_external_url":49},{},"Perimeter","GridSection",{"type":66,"content":1254},[1255,1263],{"type":112,"attrs":1256,"content":1257},{"textAlign":139},[1258],{"text":1259,"type":75,"marks":1260},"Long fence lines, blind spots, and after-hours gaps. No one is watching most of it, most of the time.",[1261],{"type":149,"attrs":1262},{"color":151},{"type":112,"attrs":1264},{"textAlign":139},{"_uid":1266,"type":18,"heading":1267,"component":1252,"description":1268},"08a5d38d-c705-4c3a-a7c4-61a9b4dea296","The Gate",{"type":66,"content":1269},[1270],{"type":112,"attrs":1271,"content":1272},{"textAlign":139},[1273],{"text":1274,"type":75,"marks":1275},"Manual greetings. Hand-waves. Paper logs that go missing. The frontline is the weakest link.",[1276],{"type":149,"attrs":1277},{"color":151},{"_uid":1279,"type":18,"heading":1280,"component":1252,"description":1281},"83d62b05-94aa-43c9-bd2c-8ae84ca8889d","Driver Identity",{"type":66,"content":1282},[1283],{"type":112,"attrs":1284,"content":1285},{"textAlign":139},[1286],{"text":1287,"type":75,"marks":1288},"Physical licenses, eyeball checks. No way to catch a fake, no way to match driver to load.",[1289],{"type":149,"attrs":1290},{"color":151},{"_uid":1292,"type":18,"heading":1293,"component":1252,"description":1294},"7ff07fde-b25c-4b26-b694-282aca37abd5","Carrier Identity",{"type":66,"content":1295},[1296],{"type":112,"attrs":1297,"content":1298},{"textAlign":139},[1299],{"text":1300,"type":75,"marks":1301},"A name and a city. No safety record. No authority check. The riskiest carriers blend in.",[1302],{"type":149,"attrs":1303},{"color":151},{"_uid":1305,"type":18,"heading":1306,"component":1252,"description":1307},"0dc8384a-b590-4830-9134-e68bdc1e3628","Retail Chargebacks",{"type":66,"content":1308},[1309],{"type":112,"attrs":1310,"content":1311},{"textAlign":139},[1312],{"text":1313,"type":75,"marks":1314},"Chaotic dock operations create unverified counts and missing documentation, leaving shipments vulnerable to errors and fraud.",[1315],{"type":149,"attrs":1316},{"color":151},{"_uid":1318,"type":18,"heading":1319,"component":1252,"description":1320},"d133f0e5-d33c-4aa4-b945-946714a0d4b8","Lack of Visibility",{"type":66,"content":1321},[1322],{"type":112,"attrs":1323,"content":1324},{"textAlign":139},[1325],{"text":1326,"type":75,"marks":1327},"Disparate point solutions to manage yard operations, security, and chain-of-custody leave operators exposed.",[1328],{"type":149,"attrs":1329},{"color":151},"The Problem","dark",{"type":66,"content":1333},[1334],{"type":69,"attrs":1335,"content":1336},{"level":138,"textAlign":139},[1337],{"text":1338,"type":75},"Today, most of the yard runs on trust.",[],"variant-1","SectionsGrid",{"type":66,"content":1343},[1344],{"type":112,"attrs":1345,"content":1346},{"textAlign":139},[1347],{"text":1348,"type":75,"marks":1349},"Thousands of drivers, carriers, and vehicles move through every week, and the systems guarding the yard were built for paper, not for the volume or the risk.",[1350],{"type":149,"attrs":1351},{"color":553},"stacked",{"css":18,"_uid":1354,"copy":1355,"wide":25,"label":1377,"title":1378,"buttons":1385,"component":1239,"top_notch":49,"bottom_notch":49,"isFullscreen":49,"content_blocks":1386,"subscribe_form":49,"background_type":1387,"multipleColumns":49,"background_image":1388,"background_theme":18,"buttons_underlined":49,"isFollowingLogosGrid":49},"a8170330-9266-4622-97f6-f9ccf1b208ea",{"type":66,"content":1356},[1357],{"type":112,"attrs":1358,"content":1359},{"textAlign":139},[1360,1365,1372],{"text":1361,"type":75,"marks":1362},"Terminal Operating System",[1363],{"type":149,"attrs":1364},{"color":553},{"text":1366,"type":75,"marks":1367},"TM",[1368,1370],{"type":149,"attrs":1369},{"color":553},{"type":1371},"superscript",{"text":1373,"type":75,"marks":1374}," delivers a multi-layered security solution that protects your yard from every angle from gate to dock.",[1375],{"type":149,"attrs":1376},{"color":553},"The Solution",{"type":66,"content":1379},[1380],{"type":69,"attrs":1381,"content":1382},{"level":138,"textAlign":139},[1383],{"text":1384,"type":75},"Multiple Levels of Security Built In to Yard Operations",[],[],"center-down",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":1389},{},{"_uid":1391,"items":1392,"button":1438,"component":1439,"button_link":1440,"button_label":1441},"b5c49656-a265-4fee-b84d-aee8d7889e50",[1393,1406,1414,1422,1430],{"_uid":1394,"image":1395,"title":1399,"content":1400,"component":1401,"additional_info":1402},"c7f3d598-35d9-44a3-9429-3186dd172e32",{"id":1396,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1397,"copyright":18,"fieldtype":1105,"meta_data":1398,"is_external_url":49},183572275752396,"/storyblok/f/337048/781x544/937b5e304e/gate-security.jpeg",{},"CV-Powered Digital Gate","The check-in you already run is security infrastructure. Terminal's YOS already eliminates whole categories of yard risk simply by digitizing the gate. Paper goes away. Trust is replaced with a record.","FeaturesGridItem",{"type":66,"content":1403},[1404],{"type":112,"attrs":1405},{"textAlign":139},{"_uid":1407,"image":1408,"title":1412,"content":1413,"component":1401},"68f84f59-0d4b-4365-ab42-67f9ed44c7fb",{"id":1409,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1410,"copyright":18,"fieldtype":1105,"meta_data":1411,"is_external_url":49},183572829838814,"/storyblok/f/337048/1166x716/a181a22a47/perimeter-security.jpg",{},"Perimeter Security","The fence line and the gate were always blind. Close the gap with enterprise-grade cloud cameras, fully integrated into the Terminal YOS\nview so footage is searchable, alerts are routed automatically, and yard operators see camera feeds where they already see yard operations.",{"_uid":1415,"image":1416,"title":1420,"content":1421,"component":1401,"additional_info":18},"65f0c022-9d60-4630-8d95-9ff5ac0e18dc",{"id":1417,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1418,"copyright":18,"fieldtype":1105,"meta_data":1419,"is_external_url":49},175444262366105,"/storyblok/f/337048/1638x1076/1ce8aa1225/truck.png",{},"Carrier Risk Assessment","Know who's at the gate before they're at the\ngate. Today, a DOT scan returns a carrier name and a city. This layer turns that lookup into a structured risk signal — authority, insurance, safety rating, OOS history, fleet shape — all from FMCSA data Terminal already pulls.\n",{"_uid":1423,"image":1424,"title":1428,"content":1429,"component":1401},"537c4ce4-6c03-4b75-bea9-cb34da6fdc52",{"id":1425,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1426,"copyright":18,"fieldtype":1105,"meta_data":1427,"is_external_url":49},183574168374775,"/storyblok/f/337048/1128x1038/eee5529097/driver-id-verification.jpg",{},"Driver Identity Verification","The visual ID check is the part of the gate that hasn't changed in twenty years. Operators glance at a card, hand it back, and wave the truck through. Replace that moment with a real verification: scan the document, read it accurately, prove it's real, and match it to the driver\nexpected on this load.",{"_uid":1431,"image":1432,"title":1436,"content":1437,"component":1401},"9750b3ef-0b4c-4ddc-8af4-d8c1bbbef15d",{"id":1433,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1434,"copyright":18,"fieldtype":1105,"meta_data":1435,"is_external_url":49},183574898916863,"/storyblok/f/337048/813x715/7b8d5e1d88/trailer-seal.jpeg",{},"Load Verification","Within existing dock workflows, document what actually leaves the yard (including seal numbers, container condition, and load configuration) defeating retail chargeback fraud and producing the ISO 17712 seal record CTPAT and modern cargo insurers expect.",[],"FeaturesGrid",{"id":817,"url":18,"linktype":19,"fieldtype":20,"cached_url":818},"LEARN MORE",{"_uid":1443,"component":1444,"case_study":1445},"82ec1011-780e-4e6a-8ecb-d256d37fe04a","CaseStudyReference",[1446],{"name":1447,"created_at":1448,"published_at":1449,"updated_at":1450,"id":1451,"uuid":1452,"content":1453,"slug":1505,"full_slug":1506,"sort_by_date":139,"position":1507,"tag_list":1508,"is_startpage":49,"parent_id":1509,"meta_data":139,"group_id":1510,"first_published_at":1511,"release_id":139,"lang":1161,"path":139,"alternates":1512,"default_full_slug":139,"translated_slugs":139,"_stopResolving":25},"Security Quote and Data","2026-06-03T20:30:43.818Z","2026-06-29T14:46:45.384Z","2026-06-29T14:46:45.401Z",183619763503262,"aff4be92-2645-4eb2-8b08-f6c0a7dd82c5",{"_uid":1454,"logo":1455,"label":1459,"media":1460,"stats":1462,"theme":1331,"title":18,"button":1472,"content":1478,"reverse":49,"component":1490,"media_fit":1491,"media_aspect":1492,"testimonial_text":1493},"fc9798ac-75d8-4e7e-b797-0ce73de61a74",{"id":1456,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1457,"copyright":18,"fieldtype":1105,"meta_data":1458,"is_external_url":49},183621247309696,"/storyblok/f/337048/300x67/84f6cd4407/terminal-color.svg",{},"PRESS RELEASE",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":1461},{},[1463,1468],{"_uid":1464,"label":1465,"value":1466,"component":1467},"05ec1aab-f952-481e-8a6a-2ff994dec137","cargo theft losses in North America last year","$725M","CaseStudyStat",{"_uid":1469,"label":1470,"value":1471,"component":1467},"f0899509-992e-42c2-815f-f21077271a46","increase in cargo identity fraud complaints","438%",[1473],{"_uid":1474,"link":1475,"label":1477,"component":28},"bd1440d3-28d3-4f9b-97e5-b6022eba302d",{"id":18