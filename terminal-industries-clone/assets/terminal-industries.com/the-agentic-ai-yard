,{"data":1213,"headers":2246},{"story":1214,"cv":1163,"rels":2099,"links":2245},{"name":179,"created_at":1215,"published_at":1216,"updated_at":1217,"id":180,"uuid":176,"content":1218,"slug":181,"full_slug":181,"sort_by_date":139,"position":2095,"tag_list":2096,"is_startpage":49,"parent_id":1157,"meta_data":139,"group_id":2097,"first_published_at":1216,"release_id":139,"lang":1161,"path":139,"alternates":2098,"default_full_slug":139,"translated_slugs":139},"2025-12-09T18:39:41.895Z","2025-12-22T19:56:04.445Z","2025-12-22T19:56:04.518Z",{"_uid":1219,"body":1220,"component":2090,"seo_image":2091,"seo_title":2093,"show_footer":25,"seo_description":2094},"f9c66e72-a90b-4960-9519-70766d4676ea",[1221,1240,1344,1366,1465,1532,1548,1567,1896],{"css":18,"_uid":1222,"copy":1223,"wide":25,"label":179,"title":1227,"buttons":1234,"component":1235,"top_notch":49,"bottom_notch":25,"isFullscreen":25,"content_blocks":1236,"subscribe_form":49,"background_type":1237,"multipleColumns":49,"background_image":1238,"background_theme":18,"buttons_underlined":49,"isFollowingLogosGrid":49},"609867cb-bb89-46b7-9f6a-80b80789b29e",{"type":66,"content":1224},[1225],{"type":112,"attrs":1226},{"textAlign":139},{"type":66,"content":1228},[1229],{"type":69,"attrs":1230,"content":1231},{"level":138,"textAlign":139},[1232],{"text":1233,"type":75},"The Only Solution That Turns Your Yard Into An Autonomous, AI-Driven Asset",[],"SectionIntroduction",[],"canvas_grid_waves",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":1239},{},{"_uid":1241,"items":1242,"label":1325,"theme":1326,"title":1327,"button":1335,"variant":1336,"component":1337,"paragraph":1338,"top_notch":49,"bottom_notch":49,"background_type":1342,"bottom_gradient":49,"paragraph_layout":1343,"show_bottom_extensions":49},"60368e29-749f-47e4-830e-ebda0c602f39",[1243,1261,1278,1295,1310],{"_uid":1244,"image":1245,"heading":1249,"component":1250,"description":1251},"8e3d4388-ae78-4375-a759-d5849a4176b9",{"id":1246,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1247,"copyright":18,"fieldtype":1105,"meta_data":1248,"is_external_url":49},118785565217004,"/storyblok/f/337048/1024x1024/ed91836e67/mesh-6.png",{},"High Operational Density","GridSection",{"type":66,"content":1252},[1253],{"type":112,"attrs":1254,"content":1255},{"textAlign":139},[1256],{"text":1257,"type":75,"marks":1258},"Yards are full of moving parts—trailers, trucks, containers, docks. Small inefficiencies compound quickly, making automation gains significant.",[1259],{"type":149,"attrs":1260},{"color":151},{"_uid":1262,"image":1263,"heading":1267,"component":1250,"description":1268},"e5ac2d54-9e74-472c-b86d-f2745756f8e3",{"id":1264,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1265,"copyright":18,"fieldtype":1105,"meta_data":1266,"is_external_url":49},118785565122791,"/storyblok/f/337048/1024x1024/b2c252fc91/mesh-7.png",{},"Structured Environments",{"type":66,"content":1269},[1270],{"type":112,"attrs":1271,"content":1272},{"textAlign":139},[1273],{"text":1274,"type":75,"marks":1275},"Yards are relatively bounded and sensor-rich, making it easier for AI agents to map, monitor, and intervene effectively.",[1276],{"type":149,"attrs":1277},{"color":151},{"_uid":1279,"image":1280,"heading":1284,"component":1250,"description":1285},"cbe1546d-1f03-4102-a6cd-7271c732bd3a",{"id":1281,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1282,"copyright":18,"fieldtype":1105,"meta_data":1283,"is_external_url":49},118785565229293,"/storyblok/f/337048/1024x1024/1d9a7be32f/mesh-9.png",{},"Data Availability",{"type":66,"content":1286},[1287],{"type":112,"attrs":1288,"content":1289},{"textAlign":139},[1290],{"text":1291,"type":75,"marks":1292},"Modern yards already generate massive streams of data via cameras, gates, telematics, and sensors, providing the foundation for agentic AI to learn and act.",[1293],{"type":149,"attrs":1294},{"color":151},{"_uid":1296,"image":1297,"heading":1299,"component":1250,"description":1300},"017ed2f5-c23c-431e-8dc6-4b5cad9fac26",{"id":1281,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1282,"copyright":18,"fieldtype":1105,"meta_data":1298,"is_external_url":49},{},"Hard to Manage at Scale",{"type":66,"content":1301},[1302],{"type":112,"attrs":1303,"content":1304},{"textAlign":139},[1305],{"text":1306,"type":75,"marks":1307},"The complex, chaotic nature of high volume yards makes them difficult for humans to manage at scale safely and efficiently.",[1308],{"type":149,"attrs":1309},{"color":151},{"_uid":1311,"image":1312,"heading":1314,"component":1250,"description":1315},"7d2bd18a-dcdd-4d9b-9f0f-90a2f64f7bfb",{"id":1281,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1282,"copyright":18,"fieldtype":1105,"meta_data":1313,"is_external_url":49},{},"Clear ROI",{"type":66,"content":1316},[1317],{"type":112,"attrs":1318,"content":1319},{"textAlign":139},[1320],{"text":1321,"type":75,"marks":1322},"Even modest efficiency gains—faster trailer moves, reduced idle time, fewer errors—translate directly to cost savings.",[1323],{"type":149,"attrs":1324},{"color":151},"Why Agentic AI in the Yard","white",{"type":66,"content":1328},[1329],{"type":69,"attrs":1330,"content":1332},{"level":1331,"textAlign":139},3,[1333],{"text":1334,"type":75},"Agentic systems in logistics anticipate issues and act automatically, rather than merely reacting. They orchestrate complex, interdependent workflows in real time, dynamically balancing priorities. By handling exceptions intelligently, they reduce delays and errors without constant human oversight. ",[],"variant-2","SectionsGrid",{"type":66,"content":1339},[1340],{"type":112,"attrs":1341},{"textAlign":139},"green_top_animation","stacked",{"css":18,"_uid":1345,"copy":1346,"wide":25,"label":1353,"title":1354,"buttons":1361,"component":1235,"top_notch":49,"bottom_notch":49,"isFullscreen":49,"content_blocks":1362,"subscribe_form":49,"background_type":1363,"multipleColumns":49,"background_image":1364,"background_theme":18,"buttons_underlined":49,"isFollowingLogosGrid":49},"5236a7b1-b560-43d5-988b-89dd97d108f2",{"type":66,"content":1347},[1348],{"type":112,"attrs":1349,"content":1350},{"textAlign":139},[1351],{"text":1352,"type":75},"Our AI-agentic yard management system actively orchestrates yard operations in real time, autonomously optimizing trailer movements, dock assignments, and spotter tasks as conditions change—going far beyond systems that merely track and report data. Unlike traditional SaaS and infrastructure-heavy solutions that struggled to adapt to the complexity and variability of modern yards, AI combined with computer vision now delivers a scalable, cost-effective platform that drives adoption, improves utilization, and delivers measurable ROI within months.","The Terminal AI-Native Yard",{"type":66,"content":1355},[1356],{"type":69,"attrs":1357,"content":1358},{"level":138,"textAlign":139},[1359],{"text":1360,"type":75},"Why AI-Native is Better",[],[],"none",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":1365},{},{"_uid":1367,"items":1368,"button":1463,"component":1464},"9a019ea4-16e4-458b-bd3f-28a972cb1e73",[1369,1386,1406,1425,1444],{"_uid":1370,"image":1371,"label":1375,"title":1376,"button":1377,"content":1378,"component":1385},"37288a79-2982-43ff-a5bc-0581b60a72c1",{"id":1372,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1373,"copyright":18,"fieldtype":1105,"meta_data":1374,"is_external_url":49},121331987857421,"/storyblok/f/337048/4253x6379/05d2abede9/ahmed-u5iht0uqq2c-unsplash.jpg",{},"THE FOUNDATION","We Decoded Yard Operations",[],{"type":66,"content":1379},[1380],{"type":112,"attrs":1381,"content":1382},{"textAlign":139},[1383],{"text":1384,"type":75},"We created an \"ontology\" (a structured map) of the yard that has decoded every complex operation and asset to act as the foundation of the agentic AI models.","FeaturesGridItemAdvanced",{"_uid":1387,"image":1388,"label":1392,"title":1393,"button":1394,"content":1395,"component":1385},"20bbcc00-adb4-43e5-8eec-381fc3f2bbf7",{"id":1389,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1390,"copyright":18,"fieldtype":1105,"meta_data":1391,"is_external_url":49},120918136011958,"/storyblok/f/337048/6000x4000/c97fc832fa/ai6.jpg",{},"THE ENGINE","Orchestrate Missions Instead of Singular Tasks",[],{"type":66,"content":1396},[1397],{"type":112,"attrs":1398,"content":1399},{"textAlign":139},[1400],{"text":1401,"type":75,"marks":1402},"We use our system to build durable, AI-powered workflows that go beyond a static, rearview human playbook. Our agentic system links missions intelligently based on real-time events and manages dependencies and schedules tasks across all actors to achieve strategic goals (e.g. \"minimize dwell time\").",[1403],{"type":149,"attrs":1404},{"color":1405},"#454742",{"_uid":1407,"image":1408,"label":1412,"title":1413,"button":1414,"content":1415,"component":1385},"51f376be-a4bd-4a79-b229-4fa410f56651",{"id":1409,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1410,"copyright":18,"fieldtype":1105,"meta_data":1411,"is_external_url":49},96822800025492,"/storyblok/f/337048/2862x1580/d917346ffc/l.webp",{},"THE OUTCOME","Delivering on Certainties, Not Guessing with Probabilities",[],{"type":66,"content":1416},[1417],{"type":112,"attrs":1418,"content":1419},{"textAlign":139},[1420],{"text":1421,"type":75,"marks":1422},"In core logistics, where precision is non-negotiable, deterministic AI ensures that every routing decision and inventory calculation is predictable, repeatable, and audit-ready. By eliminating the \"black box\" uncertainty of probabilistic models, it provides the absolute reliability required to manage complex supply chains without the risk of hallucinated data or inconsistent outcomes.",[1423],{"type":149,"attrs":1424},{"color":1405},{"_uid":1426,"image":1427,"label":1431,"title":1432,"button":1433,"content":1434,"component":1385},"9b1420b7-410d-4093-953c-630b96ca09d2",{"id":1428,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1429,"copyright":18,"fieldtype":1105,"meta_data":1430,"is_external_url":49},120918136036541,"/storyblok/f/337048/4059x2682/f932538dc6/logistics-network2.jpg",{},"THE CYCLE","Learns and Improves in Real-Time",[],{"type":66,"content":1435},[1436],{"type":112,"attrs":1437,"content":1438},{"textAlign":139},[1439],{"text":1440,"type":75,"marks":1441},"Well beyond simple automation, Terminal's AI system learns how your yard operates over time and continuously improves its algorithms to both predict better outcomes and make better decisions in real-time.",[1442],{"type":149,"attrs":1443},{"color":1405},{"_uid":1445,"image":1446,"label":1450,"title":1451,"button":1452,"content":1453,"component":1385},"5ab809bf-957c-47dc-9534-3a19cd8fc2fa",{"id":1447,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1448,"copyright":18,"fieldtype":1105,"meta_data":1449,"is_external_url":49},120918136016055,"/storyblok/f/337048/2827x3533/7f8462f6a6/logistics-port.jpg",{},"THE VALUE","AI Built In, Not Bolt On",[],{"type":66,"content":1454},[1455],{"type":112,"attrs":1456,"content":1457},{"textAlign":139},[1458],{"text":1459,"type":75,"marks":1460},"Unlike traditional systems that tack on agentic capabilities, our AI-native platform is built from the ground up to let intelligent agents act, coordinate, and make decisions in real time. This means faster, more reliable, and fully autonomous workflows that actually drive results—without the friction and limitations of legacy solutions.",[1461],{"type":149,"attrs":1462},{"color":1405},[],"FeaturesGrid",{"_uid":1466,"component":1467,"case_study":1468},"d7f2db89-de7e-43fe-8019-dfb7d4afed9d","CaseStudyReference",[1469],{"name":1470,"created_at":1471,"published_at":1472,"updated_at":1473,"id":1474,"uuid":1475,"content":1476,"slug":1524,"full_slug":1525,"sort_by_date":139,"position":1526,"tag_list":1527,"is_startpage":49,"parent_id":1528,"meta_data":139,"group_id":1529,"first_published_at":1530,"release_id":139,"lang":1161,"path":139,"alternates":1531,"default_full_slug":139,"translated_slugs":139,"_stopResolving":25},"McKinsey AI Forecast","2025-12-16T20:31:05.046Z","2026-06-29T14:46:31.372Z","2026-06-29T14:46:31.385Z",123811696856456,"a45be6ab-52ec-4fe5-9802-b8fea64e0727",{"_uid":1477,"logo":1478,"label":1482,"media":1483,"stats":1485,"theme":1495,"title":18,"button":1496,"content":1501,"reverse":49,"component":1509,"media_fit":1510,"media_aspect":1511,"testimonial_text":1512},"fc9798ac-75d8-4e7e-b797-0ce73de61a74",{"id":1479,"alt":18,"name":18,"focus":18,"title":18,"source":18,"filename":1480,"copyright":18,"fieldtype":1105,"meta_data":1481,"is_external_url":49},123814070874060,"/storyblok/f/337048/2379x895/97be79f0fe/mckinsey_-_company-logo-wine.png",{},"Market Research",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":1105,"meta_data":1484},{},[1486,1491],{"_uid":1487,"label":1488,"value":1489,"component":1490},"05ec1aab-f952-481e-8a6a-2ff994dec137","reduction in the lead time for producing documentation","60%","CaseStudyStat",{"_uid":1492,"label":1493,"value":1494,"component":1490},"f0899509-992e-42c2-815f-f21077271a46","savings from auto-generating shipping documents and reducing human errors","20%","light",[1497],{"_uid":1498,"link":1499,"label":132,"component":28},"bd1440d3-28d3-4f9b-97e5-b6022eba302d",{"id":18,"url":1500,"linktype":96,"fieldtype":20,"cached_url":1500},"https://www.mckinsey.com/capabilities/operations/our-insights/beyond-automation-how-gen-ai-is-reshaping-supply-chains",{"type":66,"content":1502},[1503],{"type":69,"attrs":1504,"content":1505},{"level":1331,"textAlign":139},[1506,1508],{"text":1507,"type":75},"Gen AI is revolutionizing the logistics industry. It’s poised to boost performance and trillions of dollars in operations, with roughly $190 billion in travel and logistics and $18 billion in supply chain operations.",{"type":618},"CaseStudy","float","auto",{"type":66,"content":1513},[1514,1516],{"type":112,"attrs":1515},{"textAlign":139},{"type":1517,"content":1518},"blockquote",[1519],{"type":112,"attrs":1520,"content":1521},{"textAlign":139},[1522],{"text":1523,"type":75},"AI offers value-clearing opportunities across the entire logistics operations value chain...including core operations like planning, optimization, warehousing, transportation, and asset maintenance.","mckinsey-ai-forecast","global/case-studies/mckinsey-ai-forecast",-20,[],123707045129673,"663c319b-cdb7-488d-8c62-003f1a9902f9","2025-12-22T19:56:25.423Z",[],{"_uid":1533,"text":1534,"subtitle":1544,"component":1547},"af81bdc4-54ef-4904-afa5-6866fb329014",{"type":66,"content":1535},[1536],{"type":69,"attrs":1537,"content":1539},{"level":138,"textAlign":1538},"left",[1540],{"text":1541,"type":75,"marks":1542},"This is only the start. With an AI-native platform in place, Terminal helps operators take a critical step closer to the vision of a lights-out yard where agentic workflows enable autonomous edge devices, robotics, and vehicles in a connected system from highway to warehouse. ",[1543],{"type":710},{"type":66,"content":1545},[1546],{"type":112},"InfoSection",{"_uid":1549,"posts":1550,"title":1557,"component":1561,"intro_text":1562,"content_headline":1566},"52daa67c-fb5b-492e-9c70-58bd62a0ff5c",[1551,1552,1553,1554,1555,1556],"3380d8c4-6f68-4af0-85a6-89b4567d6073","fb794483-8647-4db2-9a09-bd9b8bbcf60d","605bf86a-9a8a-41b2-899f-e03361dc402e","f6a443a2-1954-45f9-b615-80713d815ea1","042810f6-1a74-4145-ada9-2600e76d0681","8158c4aa-2998-4ba4-a3f5-998987c00907",{"type":66,"content":1558},[1559],{"type":112,"attrs":1560},{"textAlign":139},"FeaturedBlogPosts",{"type":66,"content":1563},[1564],{"type":112,"attrs":1565},{"textAlign":139},"AI in Logistics and Yard Automation",{"_uid":1568,"tabs":1569,"content":1871,"component":1895},"0301b78e-9121-4d9b-84f4-85297849a294",[1570,1642,1748,1791],{"_uid":1571,"items":1572,"label":1640,"component":1641},"878b66b1-6420-40da-837e-b2e224002959",[1573,1588,1601,1614,1627],{"_uid":1574,"title":1575,"content":1576,"component":1587},"f4dc4a1c-8cd7-42fa-86a0-8fc4e6b17f38","Resistance to operational change",{"type":66,"content":1577},[1578],{"type":112,"attrs":1579,"content":1580},{"textAlign":139},[1581],{"text":1582,"type":75,"marks":1583},"Yards traditionally rely on manual processes and are resistant to change. This ingrained culture makes it difficult to introduce new technology. Terminal's approach provides a strong ROI case to business leaders, making the financial benefits of change compelling, while its simple, turnkey deployment and managed infrastructure reduce the friction of adoption.",[1584],{"type":149,"attrs":1585},{"color":1586},"#1B1C1D","TabbedAccordionItem",{"_uid":1589,"title":1590,"content":1591,"component":1587},"8b0baaf3-096d-4fce-a662-99fbe6d96811","Worker resistance to automation",{"type":66,"content":1592},[1593],{"type":112,"attrs":1594,"content":1595},{"textAlign":139},[1596],{"text":1597,"type":75,"marks":1598},"Workers worry about losing their jobs to new technology. This fear can lead to resistance from frontline staff and create a negative environment for adoption. Terminal uses a human-in-the-loop onboarding process that redefines roles, allowing staff to be redeployed to higher-value tasks, and provides ongoing support, which alleviates job security fears.",[1599],{"type":149,"attrs":1600},{"color":18},{"_uid":1602,"title":1603,"content":1604,"component":1587},"05da1943-0fc8-4913-9896-53a0c338efd8","Skepticism from failed pilots",{"type":66,"content":1605},[1606],{"type":112,"attrs":1607,"content":1608},{"textAlign":139},[1609],{"text":1610,"type":75,"marks":1611},"Customers are wary of new solutions due to past failures with other vendors. This long memory of past disappointments makes them cautious about investing again. Terminal builds trust with referenceable customers and proven performance, demonstrating a faster time-to-value (5 days vs. competitors' 5+ months) and lower deployment costs through rapid, successful results.",[1612],{"type":149,"attrs":1613},{"color":1586},{"_uid":1615,"title":1616,"content":1617,"component":1587},"48c2d578-217c-4691-b7ae-cbb28ab5ffa5","Fear of workflow disruption",{"type":66,"content":1618},[1619],{"type":112,"attrs":1620,"content":1621},{"textAlign":139},[1622],{"text":1623,"type":75,"marks":1624},"Operators are afraid that new technology will break their existing, established, and profitable processes. This fear of risk outweighs the upside benefits for many companies. Terminal’s simple, turnkey deployment model and modular, on/off capability minimize this risk, allowing customers to start small and integrate the solution without a complete overhaul of their operations.",[1625],{"type":149,"attrs":1626},{"color":1586},{"_uid":1628,"title":1629,"content":1630,"component":1587},"9e0764a8-67a0-4233-ad5c-6b4c0efc8fec","Cybersecurity and privacy risks",{"type":66,"content":1631},[1632],{"type":112,"attrs":1633,"content":1634},{"textAlign":139},[1635],{"text":1636,"type":75,"marks":1637},"New interconnected yard systems introduce new vulnerabilities and data management risks. Companies with legacy systems or fragmented operations are especially vulnerable to these threats. As a fully managed solution with a unified, cloud-based platform, Terminal provides a secure, single-source system that is inherently more secure than managing a fragmented collection of different legacy tools.",[1638],{"type":149,"attrs":1639},{"color":1586},"Change Mgmt","TabbedAccordionTab",{"_uid":1643,"items":1644,"label":1747,"component":1641},"783c9eee-7850-4a11-8641-f66e61b7e0cd",[1645,1658,1671,1684,1697,1721,1734],{"_uid":1646,"title":1647,"content":1648,"component":1587},"cf26ce72-18b1-4626-ad38-0408f71a162d","Complex system integration challenges",{"type":66,"content":1649},[1650],{"type":112,"attrs":1651,"content":1652},{"textAlign":139},[1653],{"text":1654,"type":75,"marks":1655},"New technology often doesn't fit with a customer's legacy software ecosystem. This creates a risk of operational disruption and requires significant resources to build custom integrations. Terminal's modular, API-based platform is designed for seamless integration, easily connecting with existing business systems both upstream and downstream.",[1656],{"type":149,"attrs":1657},{"color":1586},{"_uid":1659,"title":1660,"content":1661,"component":1587},"9fef7fe6-dca1-4f01-989d-2d2557c945f8","Lack of on-site IT infrastructure",{"type":66,"content":1662},[1663],{"type":112,"attrs":1664,"content":1665},{"textAlign":139},[1666],{"text":1667,"type":75,"marks":1668},"Yards often lack reliable power, lighting, or internet access. This poor infrastructure makes it difficult to deploy and operate new technology. Terminal's solution includes a fully managed infrastructure that can bundle power, network, lighting, and cameras into a single, affordable annual fee.",[1669],{"type":149,"attrs":1670},{"color":1586},{"_uid":1672,"title":1673,"content":1674,"component":1587},"a830fd73-562b-47c4-9094-0f65e7d60924","Limited technical staff",{"type":66,"content":1675},[1676],{"type":112,"attrs":1677,"content":1678},{"textAlign":139},[1679],{"text":1680,"type":75,"marks":1681},"Operators that do not have the in-house expertise to set up and maintain complex technology struggle to manage deployments and troubleshoot issues. Terminal provides a turnkey deployment and training model with robust delivery and support processes, ensuring a smooth and hands-off implementation.",[1682],{"type":149,"attrs":1683},{"color":1586},{"_uid":1685,"title":1686,"content":1687,"component":1587},"116ab842-f23a-411d-aa98-dd36bc98ab13","Fragmented yard technology market",{"type":66,"content":1688},[1689],{"type":112,"attrs":1690,"content":1691},{"textAlign":139},[1692],{"text":1693,"type":75,"marks":1694},"The market is crowded with old technology and no unified solutions. This forces customers to evaluate numerous point solutions that don't integrate well. Terminal builds an all-in-one solution that avoids the need for multiple, inadequate products that are costly and fail to deliver real ROI.",[1695],{"type":149,"attrs":1696},{"color":1586},{"_uid":1698,"title":1699,"content":1700,"component":1587},"08e4a878-6d44-4874-b9d2-f81d8d78be6b","Fragmented technology across yards",{"type":66,"content":1701},[1702],{"type":112,"attrs":1703,"content":1704},{"textAlign":139},[1705,1710,1716],{"text":1706,"type":75,"marks":1707},"Different yards often use different, inconsistent tools. This lack of standardization leads to poor data quality and makes it difficult to manage a portfolio of yards. Terminal provides a unified, AI-driven \"",[1708],{"type":149,"attrs":1709},{"color":1586},{"text":1711,"type":75,"marks":1712},"OS for the Yard",[1713,1715],{"type":149,"attrs":1714},{"color":1586},{"type":710},{"text":1717,"type":75,"marks":1718},"\" that integrates with legacy systems and TMS/WMS, ensuring consistency across a customer's entire operation.",[1719],{"type":149,"attrs":1720},{"color":1586},{"_uid":1722,"title":1723,"content":1724,"component":1587},"0431c804-8ebd-4108-ba08-38c4d97df3be","Unreliable legacy tagging technology ",{"type":66,"content":1725},[1726],{"type":112,"attrs":1727,"content":1728},{"textAlign":139},[1729],{"text":1730,"type":75,"marks":1731},"Physical tags and signals like RFID, GPS, and IoT often fail in real-world yard environments. These technologies can have accuracy issues, signal interference, or require complex maintenance. Terminal’s computer vision accurately identifies assets visually without relying on physical tags or signals, making it more scalable, less invasive, and proven accurate in deployments and a more feasible solution for yard with different load carriers.",[1732],{"type":149,"attrs":1733},{"color":1586},{"_uid":1735,"title":1736,"content":1737,"component":1587},"ed7638f4-f68c-40bb-8ec3-2b544af99786","Desire to find the perfect solution",{"type":66,"content":1738},[1739],{"type":112,"attrs":1740,"content":1741},{"textAlign":139},[1742],{"text":1743,"type":75,"marks":1744},"Operators often get bogged down by the desire for a perfect, customized solution from the start. This pursuit of a comprehensive system leads to an endless scope of work and project failure before anything can be implemented. Terminal's turnkey and simple deployment model, which delivers value in as little as 5 days, is built to counteract this, providing tangible results and a clear path to expansion without getting lost in endless customization.",[1745],{"type":149,"attrs":1746},{"color":1586},"Tech Stack",{"_uid":1749,"items":1750,"label":1790,"component":1641},"7dc17bb2-f9db-491a-9642-bfa2d753fad7",[1751,1764,1777],{"_uid":1752,"title":1753,"content":1754,"component":1587},"f5879a14-c358-4b25-853d-39a45c305ed2","High cost and ROI uncertainty",{"type":66,"content":1755},[1756],{"type":112,"attrs":1757,"content":1758},{"textAlign":139},[1759],{"text":1760,"type":75,"marks":1761},"Technology is often seen as too expensive with an unclear return on investment. Customers worry that the high installation costs and thin margins of yard operations won't justify the expense. Terminal offers affordable, turnkey, and simple bundled pricing with an all-in-one investment option and modular capabilities that allow customers to scale their investment and see a clear, fast return.",[1762],{"type":149,"attrs":1763},{"color":1586},{"_uid":1765,"title":1766,"content":1767,"component":1587},"4dadd94e-2786-4f41-a89d-820429bd25f8","Costly regulatory compliance burdens",{"type":66,"content":1768},[1769],{"type":112,"attrs":1770,"content":1771},{"textAlign":139},[1772],{"text":1773,"type":75,"marks":1774},"Meeting local regulatory requirements, such as ISR in Southern California, is a time-consuming and expensive process. Manual compliance is also prone to error and can lead to costly fines. Terminal’s ISR Compliance solution provides full automation via computer vision, which drastically reduces the risk of fines and simplifies the entire compliance process.",[1775],{"type":149,"attrs":1776},{"color":1586},{"_uid":1778,"title":1779,"content":1780,"component":1587},"e3860cc3-aadd-40fa-8425-700f37d36bd2","Flawed ROI metrics and focus",{"type":66,"content":1781},[1782],{"type":112,"attrs":1783,"content":1784},{"textAlign":139},[1785],{"text":1786,"type":75,"marks":1787},"Customers have a narrow view of ROI, often focusing only on how many people they can displace. This approach ignores other significant costs, such as driver detention and wasted capacity. Terminal's strong ROI case highlights value beyond labor, including faster time-to-value, reductions in driver detention fees, and increased asset utilization, which are more compelling to executive-level buyers.",[1788],{"type":149,"attrs":1789},{"color":1586},"Costs / ROI",{"_uid":1792,"items":1793,"label":1870,"component":1641},"c1cf55cd-f946-4e3a-ba5c-e938b84f1d40",[1794,1807,1820,1833,1857],{"_uid":1795,"title":1796,"content":1797,"component":1587},"22b39ec8-5643-4aa3-8a31-ecbf5f8023fa","Inefficient manual gate processes",{"type":66,"content":1798},[1799],{"type":112,"attrs":1800,"content":1801},{"textAlign":139},[1802],{"text":1803,"type":75,"marks":1804},"Manual, error-prone gate check-in/out processes cause delays and inefficiency. These issues result in increased driver wait times and administrative errors. Terminal enables Gate Acceleration with computer vision (CV) and tablet automation, reducing truck dwell time from 5-10 minutes to less than 5 minutes.",[1805],{"type":149,"attrs":1806},{"color":1586},{"_uid":1808,"title":1809,"content":1810,"component":1587},"8b7eecec-ede5-4473-888a-2c8d9bebbbf2","The yard black hole",{"type":66,"content":1811},[1812],{"type":112,"attrs":1813,"content":1814},{"textAlign":139},[1815],{"text":1816,"type":75,"marks":1817},"The yard is often seen as an unstructured and chaotic \"black hole\" within the supply chain. This perception causes the area to be overlooked in digital transformation efforts, even as other parts of the supply chain become more digitized. Terminal's unified platform directly addresses this problem by bringing a high degree of structure, automation, and real-time visibility to the yard, making it a visible and manageable part of the supply chain for the first time.",[1818],{"type":149,"attrs":1819},{"color":1586},{"_uid":1821,"title":1822,"content":1823,"component":1587},"eb10c825-e65b-467a-905f-7386d49a7b2f","Absence of unified industry standards",{"type":66,"content":1824},[1825],{"type":112,"attrs":1826,"content":1827},{"textAlign":139},[1828],{"text":1829,"type":75,"marks":1830},"There is a lack of standardized protocols and data formats for yard technology. This makes it challenging to integrate solutions with different systems and partners. Terminal's API-driven \"OS for the Yard\" acts as a unifying layer, built to integrate seamlessly with various legacy systems and partner platforms, effectively creating a single standard for the customer.",[1831],{"type":149,"attrs":1832},{"color":1586},{"_uid":1834,"title":1835,"content":1836,"component":1587},"c16c2bea-969d-424a-a42f-8c06ac1ee997","Poor data quality and capture",{"type":66,"content":1837},[1838],{"type":112,"attrs":1839,"content":1840},{"textAlign":139},[1841,1846,1852],{"text":1842,"type":75,"marks":1843},"Data is often messy, unreliable, or captured inconsistently across yard operations. This makes it difficult to make data-driven decisions and identify opportunities for improvement. Terminal's ",[1844],{"type":149,"attrs":1845},{"color":1586},{"text":1847,"type":75,"marks":1848},"CV and AI technology",[1849,1851],{"type":149,"attrs":1850},{"color":1586},{"type":710},{"text":1853,"type":75,"marks":1854}," create a unified platform and data lake, as computer vision is the most efficient and accurate method for yard data capture, accommodating unstructured data and providing high-quality information.",[1855],{"type":149,"attrs":1856},{"color":1586},{"_uid":1858,"title":1859,"content":1860,"component":1587},"0a13e77a-b18d-4883-bbc4-aad089e595ba","Lack of real-time visibility",{"type":66,"content":1861},[1862],{"type":112,"attrs":1863,"content":1864},{"textAlign":139},[1865],{"text":1866,"type":75,"marks":1867},"Finding trailers and conducting manual asset inventory is time-consuming and inefficient. This lack of visibility leads to wasted labor hours and lost capacity. Terminal's Cloud Capture & Asset Inventory Solution, powered by computer vision and a cloud ML pipeline, indexes asset data in real-time and automates inventory validation in just 20–30 minutes per day versus the traditional 4–6 hours.",[1868],{"type":149,"attrs":1869},{"color":1586},"Poor Ops",{"type":66,"content":1872},[1873,1887],{"type":69,"attrs":1874,"content":1875},{"level":138,"textAlign":139},[1876,1882],{"text":1877,"type":75,"marks":1878},"The Most Common",[1879,1881],{"type":149,"attrs":1880},{"color":18},{"type":710},{"text":1883,"type":75,"marks":1884}," Technology Hurdles in the Yard",[1885],{"type":149,"attrs":1886},{"color":18},{"type":112,"attrs":1888,"content":1889},{"textAlign":139},[1890],{"text":1891,"type":75,"marks":1892},"Here are the most common hurdles to technology adoption in the yard. Choose the one that is holding you back to see how Terminal can help.",[1893],{"type":149,"attrs":1894},{"color":1405},"TabbedAccordion",{"_uid":1897,"form":1898,"component":2089},"4ebc7e0d-2d6c-4b2c-b30c-2d1f1a297fb2",[1899],{"name":1900,"created_at":1901,"published_at":1902,"updated_at":1903,"id":1904,"uuid":1905,"content":1906,"slug":2081,"full_slug":2082,"sort_by_date":139,"position":2083,"tag_list":2084,"is_startpage":49,"parent_id":2085,"meta_data":139,"group_id":2086,"first_published_at":2087,"release_id":139,"lang":