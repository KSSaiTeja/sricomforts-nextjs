# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem
*.key
*.p12

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files — keep .env.example commitable as the template
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / agent tooling (local only — not part of the site)
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.cursor/
.agents/
skills-lock.json

# graphify local knowledge graph (regenerable)
graphify-out/

# Local-only folders (not part of the site)
terminal-industries-clone/
website-refs/
/assets/
/scripts/

# Temp imports / staging
.tmp/
.tmp-*/

# Project docs & offline PDFs — not shipped with the app
# Exception: chatbase KB is loaded at runtime by /api/chat
/docs/*
!/docs/chatbase-kb/

# OS / tooling noise
.turbo/
*.swp
*.swo
*~
